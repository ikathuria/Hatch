{
  "name": "hatch",
  "type": "module",
  "version": "0.0.1",
  "engines": {
    "node": ">=18.17.0"
  },
  "scripts": {
    "dev": "astro dev",
    "build": "astro build",
    "preview": "astro preview",
    "astro": "astro",
    "deploy": "npm run build && wrangler deploy",
