---
import { site } from "../content/site";
import HatchEggMark from "../components/HatchEggMark.astro";
import "../styles/global.css";
import { resolveEnv } from "../lib/server/env";
import { getOrganizerFromRequest } from "../lib/server/auth";

const { title, description } = Astro.props;
const pageTitle = title ?? `${site.brand.name}`;
const metaDescription = description ?? site.hero.description;

const env = resolveEnv(Astro.locals);
const organizer = env ? await getOrganizerFromRequest(Astro.request, env) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#121724" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>
    <script>
      (() => {
        const KEY = "hatch-theme";
        const metaTheme = document.querySelector('meta[name="theme-color"]');
        const applyTheme = (theme) => {
          document.documentElement.setAttribute("data-theme", theme);
          if (metaTheme) {
            metaTheme.setAttribute("content", theme === "light" ? "#F8F3EA" : "#121724");
          }
        };
        const saved = localStorage.getItem(KEY);
        applyTheme(saved === "light" || saved === "dark" ? saved : "dark");
      })();
    </script>
  </head>
  <body class="bg-ink text-cream">
    <div class="site-glow" aria-hidden="true"></div>
    <div class="hatch-shell" aria-hidden="true"></div>

    <header class="pointer-events-none fixed left-0 right-0 top-0 z-[100] px-6 py-6">
      <div class="pointer-events-auto mx-auto w-full max-w-6xl">
        <div class="glass-panel flex items-center justify-between px-6 py-4 shadow-2xl shadow-ink/30">
          <a href="/" class="group flex items-center gap-4 transition-all">
            <span class="badge text-ink shadow-lime/40">
              <HatchEggMark class="h-[26px] w-[18px]" />
            </span>
            <span class="text-xl font-bold tracking-tight text-cream transition-colors group-hover:text-lime">
              {site.brand.name}
            </span>
          </a>

          <nav class="hidden items-center gap-10 md:flex">
            <a class="nav-link" href="/events">Events</a>
            <a class="nav-link" href="/#features">Features</a>
            <a class="nav-link" href="/#how">How it works</a>
          </nav>

          <div class="flex items-center gap-4">
            <button
              class="theme-toggle"
              type="button"
              data-theme-toggle
              aria-label="Toggle light and dark mode"
              title="Toggle theme"
            >
              <span data-theme-icon>D</span>
            </button>
            {organizer ? (
              <>
                <button class="nav-link hidden text-xs uppercase tracking-[0.2em] sm:inline-flex" data-logout-header>
                  Log out
                </button>
                <a class="btn-primary !rounded-xl !px-8 !py-2.5 !text-xs" href="/organizer/dashboard">
                  Organizer
                </a>
              </>
            ) : (
              <>
                <a class="nav-link hidden text-xs uppercase tracking-[0.2em] sm:inline-flex" href="/organizer/login">
                  Log in
                </a>
                <a class="btn-primary !rounded-xl !px-8 !py-2.5 !text-xs" href="/organizer/signup">
                  Start hosting
                </a>
              </>
            )}
          </div>
        </div>
      </div>
    </header>

    <main class="overflow-hidden pb-20 pt-32">
      <slot />
    </main>

    <footer class="relative mt-20 border-t border-cream/10 bg-ink-muted/30 backdrop-blur-xl">
      <div class="mx-auto max-w-6xl px-6 py-20">
        <div class="grid gap-16 md:grid-cols-[1.5fr_1fr_1fr_1fr]">
          <div class="space-y-6">
            <div class="flex items-center gap-3">
              <span class="badge h-8 w-8 rounded-lg text-ink">
                <HatchEggMark class="h-5 w-[14px]" />
              </span>
              <span class="text-2xl font-bold tracking-tighter">{site.brand.name}</span>
            </div>
            <p class="max-w-xs leading-relaxed text-cream/60">{site.brand.byline}</p>
            <p class="text-sm text-cream/45">Built for smooth event operations.</p>
          </div>

          <div class="space-y-6">
            <h4 class="text-xs font-bold uppercase tracking-widest text-sky">Platform</h4>
            <ul class="space-y-4 text-sm text-cream/70">
              <li><a href="/events" class="transition-colors hover:text-lime">Find events</a></li>
              <li><a href="/#features" class="transition-colors hover:text-lime">Organizer tools</a></li>
              <li><a href="/#how" class="transition-colors hover:text-lime">How it works</a></li>
            </ul>
          </div>

          <div class="space-y-6">
            <h4 class="text-xs font-bold uppercase tracking-widest text-violet">Resources</h4>
            <ul class="space-y-4 text-sm text-cream/70">
              <li>
                <a
                  href="https://github.com/ikathuria/Hatch/blob/main/CONTRIBUTING.md"
                  class="transition-colors hover:text-lime"
                  target="_blank"
                  rel="noreferrer"
                >
                  Contributing
                </a>
              </li>
              <li><a href="/privacy" class="transition-colors hover:text-lime">Privacy policy</a></li>
              <li><a href="/terms" class="transition-colors hover:text-lime">Terms of service</a></li>
            </ul>
          </div>

          <div class="space-y-6">
            <h4 class="text-xs font-bold uppercase tracking-widest text-coral">Support</h4>
            <ul class="space-y-4 text-sm text-cream/70">
              <li>
                <a href={`mailto:${site.links.email}`} class="lowercase transition-colors hover:text-lime">
                  {site.links.email}
                </a>
              </li>
              <li><a href="/code-of-conduct" class="transition-colors hover:text-lime">Code of conduct</a></li>
              <li><a href="https://github.com/ikathuria/Hatch" class="transition-colors hover:text-lime">Documentation</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-20 flex flex-col items-center justify-between gap-6 border-t border-cream/10 pt-10 md:flex-row">
          <p class="text-xs text-cream/40">&copy; {new Date().getFullYear()} {site.brand.name}. All rights reserved.</p>
          <div class="status-pill !border-lime/20 !bg-lime/10 !text-lime text-xs">Warm Nest Lab UI</div>
        </div>
      </div>
    </footer>

    <script>
      const THEME_KEY = "hatch-theme";
      const themeBtn = document.querySelector("[data-theme-toggle]");
      const themeIcon = document.querySelector("[data-theme-icon]");
      const metaTheme = document.querySelector('meta[name="theme-color"]');

      const setTheme = (theme) => {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(THEME_KEY, theme);
        if (themeIcon) themeIcon.textContent = theme === "light" ? "L" : "D";
        if (metaTheme) metaTheme.setAttribute("content", theme === "light" ? "#F8F3EA" : "#121724");
      };

      const currentTheme = document.documentElement.getAttribute("data-theme") ?? "dark";
      if (themeIcon) themeIcon.textContent = currentTheme === "light" ? "L" : "D";

      themeBtn?.addEventListener("click", () => {
        const nextTheme = (document.documentElement.getAttribute("data-theme") ?? "dark") === "dark" ? "light" : "dark";
        setTheme(nextTheme);
      });

      const logoutBtn = document.querySelector("[data-logout-header]");
      logoutBtn?.addEventListener("click", async () => {
        try {
          const res = await fetch("/api/auth/logout", { method: "POST" });
          if (res.ok) window.location.href = "/";
        } catch {
          // no-op
        }
      });
    </script>
  </body>
</html>
