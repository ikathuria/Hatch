---
import { site } from "../content/site";
import "../styles/global.css";

const { title, description } = Astro.props;
const pageTitle = title ?? `${site.brand.name}`;
const metaDescription = description ?? site.hero.description;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#0e0b1d" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>
  </head>
  <body class="bg-ink text-cream">
    <div class="site-glow" aria-hidden="true"></div>
    <header class="sticky top-0 z-40 border-b border-ink/40 bg-ink/80 backdrop-blur">
      <div class="mx-auto flex w-full max-w-6xl items-center justify-between px-6 py-4">
        <a href="/" class="flex items-center gap-3 text-lg font-semibold tracking-tight">
          <span class="badge">EH</span>
          <span>{site.brand.name}</span>
        </a>
        <nav class="hidden items-center gap-6 text-sm font-semibold uppercase tracking-wide md:flex">
          <a class="nav-link" href="/#events">Events</a>
          <a class="nav-link" href="/#features">Features</a>
          <a class="nav-link" href="/#how">How it works</a>
        </nav>
        <div class="flex items-center gap-3">
          <a class="btn-ghost hidden sm:inline-flex" href="/organizer/login">
            Organizer login
          </a>
          <a class="btn-primary" href="/organizer/signup">
            Create an event
          </a>
        </div>
      </div>
    </header>

    <main>
      <slot />
    </main>

    <footer class="border-t border-ink/40 bg-ink/70">
      <div class="mx-auto flex w-full max-w-6xl flex-col gap-6 px-6 py-10 md:flex-row md:items-center md:justify-between">
        <div>
          <p class="text-lg font-semibold">{site.brand.name}</p>
          <p class="text-sm text-cream-70">{site.brand.byline}</p>
        </div>
        <div class="flex flex-wrap gap-4 text-sm">
          <a class="nav-link" href="/code-of-conduct">Code of Conduct</a>
          <a class="nav-link" href="/privacy">Privacy</a>
          <a class="nav-link" href={`mailto:${site.links.email}`}>{site.links.email}</a>
        </div>
      </div>
    </footer>
  </body>
</html>

