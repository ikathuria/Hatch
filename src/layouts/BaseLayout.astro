---
import { site } from "../content/site";
import HatchEggMark from "../components/HatchEggMark.astro";
import "../styles/global.css";
import { resolveEnv } from "../lib/server/env";
import { getOrganizerFromRequest } from "../lib/server/auth";

const { title, description } = Astro.props;
const pageTitle = title ?? `${site.brand.name}`;
const metaDescription = description ?? site.hero.description;

const env = resolveEnv(Astro.locals);
const organizer = env ? await getOrganizerFromRequest(Astro.request, env) : null;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={metaDescription} />
    <meta name="theme-color" content="#130f0b" />
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
    <link rel="icon" href="/favicon.ico" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <title>{pageTitle}</title>
    <script>
      (() => {
        const KEY = "hatch-theme";
        const metaTheme = document.querySelector('meta[name="theme-color"]');
        const applyTheme = (theme) => {
          document.documentElement.setAttribute("data-theme", theme);
          if (metaTheme) {
            metaTheme.setAttribute("content", theme === "light" ? "#f4eee3" : "#130f0b");
          }
        };
        const saved = localStorage.getItem(KEY);
        applyTheme(saved === "light" || saved === "dark" ? saved : "dark");
      })();
    </script>
  </head>
  <body class="bg-ink text-cream">
    <div class="site-glow" aria-hidden="true"></div>
    <div class="hatch-shell" aria-hidden="true"></div>

    <header class="pointer-events-none fixed left-0 right-0 top-0 z-[100] border-b border-cream/[0.08] bg-ink/[0.86] px-6 py-5 backdrop-blur-xl">
      <div class="pointer-events-auto mx-auto flex w-full max-w-6xl items-center justify-between gap-6">
        <a href="/" class="group flex items-center gap-3 transition-all">
          <span class="flex h-11 w-11 items-center justify-center rounded-full border border-cream/[0.12] bg-cream/[0.03] text-cream transition-colors group-hover:border-lime/[0.35] group-hover:text-lime">
            <HatchEggMark class="h-[26px] w-[18px]" />
          </span>
          <div class="space-y-0.5">
            <span class="block text-xl font-bold tracking-[-0.08em] text-cream transition-colors group-hover:text-lime">
              {site.brand.name}
            </span>
            <span class="block font-mono text-[0.65rem] uppercase tracking-[0.32em] text-cream/[0.35]">Ideas into launch</span>
          </div>
        </a>

        <nav class="hidden items-center gap-8 md:flex">
          <a class="nav-link font-mono text-xs uppercase tracking-[0.2em]" href="/events">Events</a>
          <a class="nav-link font-mono text-xs uppercase tracking-[0.2em]" href="/about">About</a>
        </nav>

        <div class="flex items-center gap-3">
            <button
              class="theme-toggle"
              type="button"
              data-theme-toggle
              aria-label="Toggle light and dark mode"
              title="Toggle theme"
            >
              <span data-theme-icon>D</span>
            </button>
            {organizer ? (
              <>
                <button class="nav-link hidden font-mono text-xs uppercase tracking-[0.2em] sm:inline-flex" data-logout-header>
                  Log out
                </button>
                <a class="btn-primary !rounded-full !px-6 !py-2.5 !text-xs" href="/organizer/dashboard">
                  Organizer
                </a>
              </>
            ) : (
              <>
                <a class="nav-link hidden font-mono text-xs uppercase tracking-[0.2em] sm:inline-flex" href="/organizer/login">
                  Log in
                </a>
                <a class="btn-primary !rounded-full !px-6 !py-2.5 !text-xs" href="/organizer/signup">
                  Start hosting
                </a>
              </>
            )}
          </div>
        </div>
      </div>
    </header>

    <main class="overflow-hidden pb-20 pt-32">
      <slot />
    </main>

    <footer class="relative mt-20 border-t border-cream/[0.08] bg-ink-muted/20">
      <div class="mx-auto max-w-6xl px-6 py-[4.5rem]">
        <div class="grid gap-14 md:grid-cols-[1.4fr_1fr_1fr]">
          <div class="space-y-5">
            <div class="flex items-center gap-3">
              <span class="flex h-10 w-10 items-center justify-center rounded-full border border-cream/[0.12] bg-cream/[0.03] text-cream">
                <HatchEggMark class="h-5 w-[14px]" />
              </span>
              <span class="text-2xl font-bold tracking-[-0.08em]">{site.brand.name}</span>
            </div>
            <p class="max-w-sm leading-relaxed text-cream/[0.62]">{site.brand.byline}</p>
            <p class="font-mono text-xs uppercase tracking-[0.22em] text-cream/[0.32]">Built for organizers. Open to builders.</p>
          </div>

          <div class="space-y-5">
            <h4 class="font-mono text-[0.7rem] uppercase tracking-[0.28em] text-sky">Platform</h4>
            <ul class="space-y-3 text-sm text-cream/70">
              <li><a href="/events" class="transition-colors hover:text-lime">Explore events</a></li>
              <li><a href="/about" class="transition-colors hover:text-lime">About Hatch</a></li>
            </ul>
          </div>

          <div class="space-y-5">
            <h4 class="font-mono text-[0.7rem] uppercase tracking-[0.28em] text-coral">Resources</h4>
            <ul class="space-y-3 text-sm text-cream/70">
              <li>
                <a
                  href="https://github.com/ikathuria/Hatch/blob/main/CONTRIBUTING.md"
                  class="transition-colors hover:text-lime"
                  target="_blank"
                  rel="noreferrer"
                >
                  Contributing
                </a>
              </li>
              <li><a href="/privacy" class="transition-colors hover:text-lime">Privacy policy</a></li>
              <li><a href="/terms" class="transition-colors hover:text-lime">Terms of service</a></li>
              <li><a href="/code-of-conduct" class="transition-colors hover:text-lime">Code of conduct</a></li>
              <li><a href={`mailto:${site.links.email}`} class="lowercase transition-colors hover:text-lime">{site.links.email}</a></li>
            </ul>
          </div>
        </div>

        <div class="mt-16 flex flex-col gap-4 border-t border-cream/[0.08] pt-8 md:flex-row md:items-center md:justify-between">
          <p class="text-xs text-cream/[0.38]">&copy; {new Date().getFullYear()} {site.brand.name}. All rights reserved.</p>
          <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-cream/[0.28]">Minimal launch infrastructure for modern hackathons</p>
        </div>
      </div>
    </footer>

    <script>
      const THEME_KEY = "hatch-theme";
      const themeBtn = document.querySelector("[data-theme-toggle]");
      const themeIcon = document.querySelector("[data-theme-icon]");
      const metaTheme = document.querySelector('meta[name="theme-color"]');

      const setTheme = (theme) => {
        document.documentElement.setAttribute("data-theme", theme);
        localStorage.setItem(THEME_KEY, theme);
        if (themeIcon) themeIcon.textContent = theme === "light" ? "L" : "D";
        if (metaTheme) metaTheme.setAttribute("content", theme === "light" ? "#f4eee3" : "#130f0b");
      };

      const currentTheme = document.documentElement.getAttribute("data-theme") ?? "dark";
      if (themeIcon) themeIcon.textContent = currentTheme === "light" ? "L" : "D";

      themeBtn?.addEventListener("click", () => {
        const nextTheme = (document.documentElement.getAttribute("data-theme") ?? "dark") === "dark" ? "light" : "dark";
        setTheme(nextTheme);
      });

      const logoutBtn = document.querySelector("[data-logout-header]");
      logoutBtn?.addEventListener("click", async () => {
        try {
          const res = await fetch("/api/auth/logout", { method: "POST" });
          if (res.ok) window.location.href = "/";
        } catch {
          // no-op
        }
      });
    </script>
  </body>
</html>
