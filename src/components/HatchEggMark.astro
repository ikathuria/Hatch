---
interface Props {
  class?: string;
  /**
   * Optional prefix to keep SVG <defs> IDs unique when multiple logos render on the page.
   * (Prevents `url(#id)` collisions for gradients/filters.)
   */
  idPrefix?: string;
}
const { class: className = "h-[26px] w-[18px]", idPrefix } = Astro.props;
const uid = idPrefix ?? `hatch-egg-${Math.random().toString(36).slice(2)}`;
---

<svg
  class={`hatch-egg-mark ${className}`}
  viewBox="0 0 200 200"
  preserveAspectRatio="xMidYMid meet"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={`${uid}-cyberShell`} x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#FCF6EA;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E7D8BE;stop-opacity:1" />
    </linearGradient>

    <radialGradient id={`${uid}-digitalDawn`} cx="50%" cy="50%" r="60%">
      <stop offset="0%" style="stop-color:#F4C96B;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#C77B24;stop-opacity:1" />
    </radialGradient>

    <linearGradient id={`${uid}-crackLine`} x1="0%" y1="0%" x2="100%" y2="100%">
      <stop offset="0%" style="stop-color:#A3C4C8;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6B8D93;stop-opacity:1" />
    </linearGradient>

    <filter id={`${uid}-glowEffect`} x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="2.2" result="coloredBlur" />
      <feMerge>
        <feMergeNode in="coloredBlur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <circle
    cx="100"
    cy="100"
    r="30"
    fill={`url(#${uid}-digitalDawn)`}
    filter={`url(#${uid}-glowEffect)`}
  />

  <path
    d="M40,110 C40,150 70,180 100,180 C130,180 160,150 160,110 L145,105 L115,125 L100,105 L85,125 L55,105 Z"
    fill={`url(#${uid}-cyberShell)`}
    stroke="#d2c2a8"
    stroke-width="1.5"
  />

  <path
    d="M40,90 C40,50 70,20 100,20 C130,20 160,50 160,90 L145,95 L115,75 L100,95 L85,75 L55,95 Z"
    class="hatch-egg-mark__top-shell"
    fill={`url(#${uid}-cyberShell)`}
    stroke="#d2c2a8"
    stroke-width="1.5"
    transform="translate(0, -8) rotate(-2, 100, 55)"
  />

  <path
    d="M96 59 84 80l20 20-11 35M111 68l-6 16"
    fill="none"
    stroke={`url(#${uid}-crackLine)`}
    stroke-linecap="round"
    stroke-linejoin="round"
    stroke-width="5"
  />
</svg>
