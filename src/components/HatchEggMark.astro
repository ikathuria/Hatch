---
interface Props {
  class?: string;
  /**
   * Optional prefix to keep SVG <defs> IDs unique when multiple logos render on the page.
   * (Prevents `url(#id)` collisions for gradients/filters.)
   */
  idPrefix?: string;
}
const { class: className = "h-[26px] w-[18px]", idPrefix } = Astro.props;
const uid = idPrefix ?? `hatch-egg-${Math.random().toString(36).slice(2)}`;
---

<svg
  class={className}
  viewBox="0 0 200 200"
  preserveAspectRatio="xMidYMid meet"
  fill="none"
  xmlns="http://www.w3.org/2000/svg"
  aria-hidden="true"
>
  <defs>
    <linearGradient id={`${uid}-cyberShell`} x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#F8FAFC;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#E2E8F0;stop-opacity:1" />
    </linearGradient>

    <linearGradient id={`${uid}-digitalDawn`} x1="0%" y1="0%" x2="0%" y2="100%">
      <stop offset="0%" style="stop-color:#22D3EE;stop-opacity:1" />
      <stop offset="100%" style="stop-color:#6366F1;stop-opacity:1" />
    </linearGradient>

    <filter id={`${uid}-glowEffect`} x="-20%" y="-20%" width="140%" height="140%">
      <feGaussianBlur stdDeviation="3" result="coloredBlur" />
      <feMerge>
        <feMergeNode in="coloredBlur" />
        <feMergeNode in="SourceGraphic" />
      </feMerge>
    </filter>
  </defs>

  <rect width="200" height="200" fill="#0F172A" rx="20" />

  <circle
    cx="100"
    cy="100"
    r="30"
    fill={`url(#${uid}-digitalDawn)`}
    filter={`url(#${uid}-glowEffect)`}
  >
    <animate attributeName="opacity" values="0.8;1;0.8" dur="2s" repeatCount="indefinite" />
  </circle>

  <path
    d="M40,110 C40,150 70,180 100,180 C130,180 160,150 160,110 L145,105 L115,125 L100,105 L85,125 L55,105 Z"
    fill={`url(#${uid}-cyberShell)`}
    stroke="#cbd5e1"
    stroke-width="1.5"
  />

  <path
    d="M40,90 C40,50 70,20 100,20 C130,20 160,50 160,90 L145,95 L115,75 L100,95 L85,75 L55,95 Z"
    fill={`url(#${uid}-cyberShell)`}
    stroke="#cbd5e1"
    stroke-width="1.5"
    transform="translate(0, -10) rotate(-3, 100, 55)"
  />
</svg>
