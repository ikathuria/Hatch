---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Judge Portal | Hatch">
  <div class="mx-auto max-w-3xl px-6 py-12">
    <section class="card !p-10 space-y-5">
      <span class="eyebrow !text-violet !bg-violet/10 !border-violet/20">Judge Portal</span>
      <h1 class="text-4xl font-bold tracking-tighter">Judge link required</h1>
      <p class="text-cream/60 leading-relaxed">
        This page needs a valid judge token in the URL. Please open the full judge link shared by the organizer.
      </p>
      <div class="flex flex-wrap gap-4 pt-2">
        <a class="btn-primary !px-8" href="/">Go home</a>
        <a class="btn-ghost !px-8" href="/organizer/login">Organizer login</a>
      </div>
    </section>
  </div>
</BaseLayout>
