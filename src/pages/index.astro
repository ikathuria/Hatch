---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../content/site";
---

<BaseLayout title={`${site.brand.name} | Hackathon hosting platform`}>
  <section class="mx-auto max-w-6xl px-6 pb-18 pt-12">
    <div class="grid gap-14 lg:grid-cols-[1.05fr_0.95fr] lg:items-center">
      <div class="space-y-8">
        <div class="space-y-4">
          <span class="eyebrow !border-lime/20 !bg-lime/[0.08] !font-mono !text-[0.68rem] !tracking-[0.24em] !text-lime">
            Launch ideas before they cool
          </span>
          <h1 class="max-w-3xl text-5xl font-bold tracking-[-0.08em] md:text-7xl">{site.hero.title}</h1>
          <p class="max-w-2xl text-lg leading-relaxed text-cream/[0.64] md:text-xl">
            {site.hero.description}
          </p>
        </div>

        <div class="flex flex-wrap gap-3">
          <a class="btn-primary !rounded-full !px-8 !py-3.5" href={site.hero.primaryCta.href}>{site.hero.primaryCta.label}</a>
          <a class="btn-ghost !rounded-full !px-8 !py-3.5 !font-mono !text-xs !uppercase !tracking-[0.2em]" href={site.hero.secondaryCta.href}>
            {site.hero.secondaryCta.label}
          </a>
          <a class="btn-ghost !rounded-full !px-8 !py-3.5 !font-mono !text-xs !uppercase !tracking-[0.2em]" href="/events">
            Explore events
          </a>
        </div>
      </div>

      <aside class="landing-orbital" aria-hidden="true">
        <div class="landing-orbital__ring landing-orbital__ring--outer"></div>
        <div class="landing-orbital__ring landing-orbital__ring--inner"></div>
        <div class="landing-orbital__glow"></div>
        <div class="landing-orbital__shell landing-orbital__shell--top"></div>
        <div class="landing-orbital__shell landing-orbital__shell--bottom"></div>
        <div class="landing-orbital__crack"></div>
        <div class="landing-orbital__label landing-orbital__label--left">prepare</div>
        <div class="landing-orbital__label landing-orbital__label--top">gather</div>
        <div class="landing-orbital__label landing-orbital__label--right">launch</div>
      </aside>
    </div>
  </section>
</BaseLayout>
