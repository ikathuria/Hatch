---
import BaseLayout from "../layouts/BaseLayout.astro";
import { site } from "../content/site";
---

<BaseLayout title={`${site.brand.name} | Hackathon hosting platform`}>
  <section class="mx-auto max-w-6xl px-6 py-16">
    <div class="grid gap-10 lg:grid-cols-[1.15fr_0.85fr] lg:items-center">
      <div class="space-y-6">
        <span class="eyebrow !border-lime/25 !bg-lime/10 !text-lime">Warm Nest Lab</span>
        <h1 class="text-5xl font-bold tracking-tight md:text-7xl">{site.hero.title}</h1>
        <p class="max-w-2xl text-lg leading-relaxed text-cream/60">{site.hero.description}</p>
        <div class="flex flex-wrap gap-3">
          <a class="btn-primary !px-8 !py-3.5" href={site.hero.primaryCta.href}>{site.hero.primaryCta.label}</a>
          <a class="btn-ghost !px-8 !py-3.5" href={site.hero.secondaryCta.href}>{site.hero.secondaryCta.label}</a>
        </div>
      </div>

      <aside class="card !p-7 space-y-5">
        <h2 class="text-xl font-bold">Why teams pick Hatch</h2>
        <ul class="space-y-3 text-sm text-cream/65">
          <li>Organizer dashboard for setup, judging, and publishing.</li>
          <li>Judge links with optional PIN and expiry controls.</li>
          <li>Public event pages with application, submission, and voting flows.</li>
        </ul>
        <div class="grid grid-cols-2 gap-3 sm:grid-cols-4 lg:grid-cols-2">
          {site.stats.map((stat) => (
            <div class="rounded-xl border border-cream/10 bg-cream/5 p-3">
              <p class="text-xs uppercase tracking-widest text-cream/45">{stat.label}</p>
              <p class="mt-1 text-lg font-bold">{stat.value}</p>
            </div>
          ))}
        </div>
      </aside>
    </div>
  </section>

  <section id="features" class="mx-auto max-w-6xl px-6 py-10">
    <div class="space-y-3">
      <span class="eyebrow !border-sky/25 !bg-sky/10 !text-sky">Organizer tools</span>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Everything needed to run one event well</h2>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-2">
      {site.features.map((feature) => (
        <article class="card !p-6">
          <h3 class="text-xl font-bold">{feature.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-cream/60">{feature.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="how" class="mx-auto max-w-6xl px-6 py-10">
    <div class="space-y-3">
      <span class="eyebrow !border-violet/25 !bg-violet/10 !text-violet">How it works</span>
      <h2 class="text-3xl font-bold tracking-tight md:text-4xl">Launch in three steps</h2>
    </div>
    <div class="mt-8 grid gap-5 md:grid-cols-3">
      {site.steps.map((step, index) => (
        <article class="card !p-6">
          <p class="text-xs font-bold uppercase tracking-widest text-cream/40">Step {index + 1}</p>
          <h3 class="mt-3 text-xl font-bold">{step.title}</h3>
          <p class="mt-2 text-sm leading-relaxed text-cream/60">{step.description}</p>
        </article>
      ))}
    </div>
  </section>

  <section id="events" class="mx-auto max-w-6xl px-6 py-12">
    <div class="mb-7 flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
      <div>
        <span class="eyebrow !border-lime/25 !bg-lime/10 !text-lime">Live events</span>
        <h2 class="mt-3 text-3xl font-bold tracking-tight md:text-4xl">Upcoming and active hackathons</h2>
      </div>
      <a class="btn-ghost !px-5 !py-3 !text-sm" href="/events">Browse all events</a>
    </div>

    <div class="grid gap-5 md:grid-cols-2" data-events-grid aria-live="polite">
      <div class="card !p-8 text-cream/40">Loading events...</div>
    </div>
  </section>

  <section class="mx-auto max-w-5xl px-6 py-14">
    <div class="card !p-10 text-center md:!p-14">
      <h2 class="text-3xl font-bold tracking-tight md:text-5xl">Ready to host your next hackathon?</h2>
      <p class="mx-auto mt-4 max-w-2xl text-cream/60">
        Create your organizer account, launch your event page, and run judging from one workspace.
      </p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a class="btn-primary !px-8 !py-3.5" href="/organizer/signup">Create organizer account</a>
        <a class="btn-ghost !px-8 !py-3.5" href="/events">See public events</a>
      </div>
    </div>
  </section>

  <script>
    const grid = document.querySelector("[data-events-grid]");

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/\"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const formatDate = (value) => {
      if (!value) return "TBD";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return new Intl.DateTimeFormat(undefined, {
        month: "short",
        day: "numeric",
        year: "numeric"
      }).format(date);
    };

    const renderEvents = (events) => {
      if (!grid) return;
      if (!events.length) {
        grid.innerHTML = '<div class="card !p-8 text-cream/45 italic border-dashed">No events are published yet.</div>';
        return;
      }

      grid.innerHTML = events
        .slice(0, 6)
        .map((event) => {
          const organizerId = String(event.organizerId || "").trim();
          const href = organizerId ? `/events/${organizerId}/${event.slug}` : `/events/${event.slug}`;
          return `
            <article class="card !p-6">
              <div class="flex items-center justify-between gap-3">
                <span class="status-pill !bg-sky/10 !text-sky !border-sky/20">${escapeHtml(event.mode || "Hackathon")}</span>
                <span class="text-xs uppercase tracking-widest text-cream/40">${escapeHtml(event.location || "Location TBD")}</span>
              </div>
              <h3 class="mt-4 text-2xl font-bold">${escapeHtml(event.title || "Untitled event")}</h3>
              <p class="mt-2 text-sm text-cream/60">${escapeHtml(event.tagline || "No tagline yet.")}</p>
              <p class="mt-4 text-xs uppercase tracking-widest text-cream/45">${formatDate(event.startDate)} - ${formatDate(event.endDate)}</p>
              <a class="btn-primary mt-5 !w-full !text-sm" href="${href}">Open event</a>
            </article>
          `;
        })
        .join("");
    };

    const loadEvents = async () => {
      if (!grid) return;
      try {
        const response = await fetch("/api/events");
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || "Unable to load events.");
        renderEvents(Array.isArray(payload.events) ? payload.events : []);
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unable to load events.";
        grid.innerHTML = `<div class="card !p-8 text-coral border-coral/20">${escapeHtml(message)}</div>`;
      }
    };

    loadEvents();
  </script>
</BaseLayout>
