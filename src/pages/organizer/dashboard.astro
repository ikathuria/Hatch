---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Organizer Dashboard | Hatch">
  <div class="mx-auto max-w-6xl px-6 py-12">
    <div class="mb-12 flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
      <div class="space-y-4">
        <span class="eyebrow !border-lime/25 !bg-lime/10 !text-lime">Organizer Workspace</span>
        <h1 class="text-4xl font-bold tracking-tighter md:text-5xl">Your events</h1>
        <p class="max-w-2xl text-cream/60">
          Manage event setup, judging, and publishing from one reliable dashboard.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-3">
        <button class="btn-ghost !px-6" data-logout type="button">Sign out</button>
        <a class="btn-primary !px-8" href="/organizer/events/new">New event</a>
      </div>
    </div>

    <div class="mb-10 grid grid-cols-1 gap-4 sm:grid-cols-3">
      <div class="card !p-6">
        <p class="text-xs font-bold uppercase tracking-widest text-cream/40">Total events</p>
        <p class="mt-3 text-3xl font-bold" id="stat-total-events">0</p>
      </div>
      <div class="card !p-6">
        <p class="text-xs font-bold uppercase tracking-widest text-cream/40">Published</p>
        <p class="mt-3 text-3xl font-bold" id="stat-live-events">0</p>
      </div>
      <div class="card !p-6">
        <p class="text-xs font-bold uppercase tracking-widest text-cream/40">Draft</p>
        <p class="mt-3 text-3xl font-bold" id="stat-draft-events">0</p>
      </div>
    </div>

    <div aria-live="polite" class="grid gap-6 md:grid-cols-2 xl:grid-cols-3" data-events-grid>
      <div class="card !p-10 text-cream/35 italic border-dashed col-span-full">Loading your events...</div>
    </div>
  </div>

  <script>
    const eventsGrid = document.querySelector("[data-events-grid]");
    const logoutButton = document.querySelector("[data-logout]");
    const totalEventsStat = document.querySelector("#stat-total-events");
    const liveEventsStat = document.querySelector("#stat-live-events");
    const draftEventsStat = document.querySelector("#stat-draft-events");

    const formatDate = (value) => {
      if (!value) return "TBD";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return new Intl.DateTimeFormat(undefined, {
        month: "short",
        day: "numeric",
        year: "numeric"
      }).format(date);
    };

    const formatRange = (start, end) => {
      if (!start && !end) return "Dates TBD";
      if (!start || !end) return formatDate(start || end);
      return `${formatDate(start)} - ${formatDate(end)}`;
    };

    const renderEmptyState = (message) => {
      if (!eventsGrid) return;
      eventsGrid.innerHTML = `
        <div class="card !p-10 text-cream/45 border-dashed col-span-full">
          <p class="text-lg font-semibold">No events yet</p>
          <p class="mt-2 text-sm text-cream/50">${message}</p>
          <a class="btn-primary mt-6 !px-6 !py-3" href="/organizer/events/new">Create your first event</a>
        </div>
      `;
    };

    const renderEvents = (events) => {
      if (!eventsGrid) return;

      const total = events.length;
      const liveCount = events.filter((event) => event.isPublished).length;
      const draftCount = total - liveCount;

      if (totalEventsStat) totalEventsStat.textContent = String(total);
      if (liveEventsStat) liveEventsStat.textContent = String(liveCount);
      if (draftEventsStat) draftEventsStat.textContent = String(draftCount);

      if (!total) {
        renderEmptyState("Create an event to unlock setup, submissions, and judging.");
        return;
      }

      eventsGrid.innerHTML = events
        .map((event) => {
          const organizerId = String(event.organizerId || "").trim();
          const publicHref = organizerId
            ? `/events/${organizerId}/${event.slug}`
            : `/events/${event.slug}`;
          const dateRange = formatRange(event.startDate, event.endDate);
          const statusLabel = event.isPublished ? "Published" : "Draft";
          const statusClass = event.isPublished
            ? "!border-lime/25 !bg-lime/10 !text-lime"
            : "!border-sky/25 !bg-sky/10 !text-sky";

          return `
            <article class="card !p-7 flex flex-col gap-6">
              <div class="flex items-start justify-between gap-4">
                <span class="status-pill ${statusClass}">${statusLabel}</span>
                <span class="text-xs uppercase tracking-widest text-cream/40">${formatDate(event.updatedAt || event.createdAt)}</span>
              </div>

              <div class="space-y-2">
                <h2 class="text-2xl font-bold tracking-tight">${event.title || "Untitled event"}</h2>
                <p class="text-sm text-cream/55">${event.tagline || "Add a short tagline in the editor."}</p>
              </div>

              <dl class="space-y-2 text-sm text-cream/55">
                <div class="flex items-center justify-between gap-3">
                  <dt class="uppercase tracking-widest text-[11px] text-cream/35">Dates</dt>
                  <dd>${dateRange}</dd>
                </div>
                <div class="flex items-center justify-between gap-3">
                  <dt class="uppercase tracking-widest text-[11px] text-cream/35">Location</dt>
                  <dd>${event.location || "Location TBD"}</dd>
                </div>
              </dl>

              <div class="mt-auto flex flex-wrap gap-3">
                <a class="btn-primary !px-5 !py-3 !text-sm" href="/organizer/events/${event.id}">Open editor</a>
                <a class="btn-ghost !px-5 !py-3 !text-sm" href="${publicHref}" target="_blank" rel="noreferrer">Public page</a>
              </div>
            </article>
          `;
        })
        .join("");
    };

    const loadEvents = async () => {
      try {
        const response = await fetch("/api/organizer/events");
        if (response.status === 401) {
          window.location.href = "/organizer/login";
          return;
        }

        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || "Unable to load events.");
        renderEvents(Array.isArray(payload.events) ? payload.events : []);
      } catch (error) {
        if (!eventsGrid) return;
        const message = error instanceof Error ? error.message : "Unable to load events.";
        eventsGrid.innerHTML = `
          <div class="card !p-10 text-coral border-coral/20 col-span-full">
            <p class="font-semibold">Dashboard unavailable</p>
            <p class="mt-2 text-sm">${message}</p>
          </div>
        `;
      }
    };

    logoutButton?.addEventListener("click", async () => {
      await fetch("/api/auth/logout", { method: "POST" });
      window.location.href = "/";
    });

    loadEvents();
  </script>
</BaseLayout>
