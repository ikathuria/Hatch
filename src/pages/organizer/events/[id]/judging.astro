---
import BaseLayout from '../../../../layouts/BaseLayout.astro';

const eventId = Astro.params.id ? String(Astro.params.id) : '';
---

<BaseLayout title="Judging | Hatch">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="flex flex-col gap-8 xl:flex-row xl:items-end xl:justify-between mb-12">
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <a href={`/organizer/events/${eventId}`} class="w-8 h-8 rounded-lg bg-white/5 flex items-center justify-center hover:bg-white/10 transition-colors">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </a>
          <span class="eyebrow !text-lime !bg-lime/10 !border-lime/20">Judging Room</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tighter" data-event-title>Loading judging workspace...</h1>
        <p class="text-cream/50 max-w-3xl leading-relaxed">
          Build the rubric, share judge links, resolve ties, and publish results when you are ready to reveal winners.
        </p>
      </div>
      <div class="flex flex-wrap items-center gap-4">
        <a class="btn-ghost !px-6" data-public-link href="#" target="_blank" rel="noreferrer">
          <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2 opacity-60"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
          Public View
        </a>
        <button class="btn-primary !px-8" type="button" data-publish-results>
          Publish Results
        </button>
      </div>
    </div>

    <div class="grid gap-6 lg:grid-cols-4 mb-8">
      <div class="card !p-6">
        <p class="text-xs font-bold uppercase tracking-widest text-cream/35 mb-2">Rubric</p>
        <p class="text-3xl font-bold" data-stat-criteria>0</p>
        <p class="text-sm text-cream/45 mt-2">Criteria configured</p>
      </div>
      <div class="card !p-6">
        <p class="text-xs font-bold uppercase tracking-widest text-cream/35 mb-2">Judge Links</p>
        <p class="text-3xl font-bold" data-stat-judge-links>0</p>
        <p class="text-sm text-cream/45 mt-2">Active or revoked links</p>
      </div>
      <div class="card !p-6">
        <p class="text-xs font-bold uppercase tracking-widest text-cream/35 mb-2">Tie Warnings</p>
        <p class="text-3xl font-bold" data-stat-ties>0</p>
        <p class="text-sm text-cream/45 mt-2">Need manual review</p>
      </div>
      <div class="card !p-6">
        <p class="text-xs font-bold uppercase tracking-widest text-cream/35 mb-2">Results</p>
        <p class="text-3xl font-bold" data-stat-results>Draft</p>
        <p class="text-sm text-cream/45 mt-2">Reveal state</p>
      </div>
    </div>

    <div class="grid gap-8 xl:grid-cols-[1.2fr_0.8fr]">
      <section class="card !p-8 space-y-8">
        <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="eyebrow !text-sky !bg-sky/10 !border-sky/20">Rubric Builder</span>
            <h2 class="section-title !mb-0 mt-4 text-4xl">Custom scoring</h2>
          </div>
          <div class="flex items-center gap-3">
            <label class="text-xs font-bold uppercase tracking-widest text-cream/40" for="score-scale">Score scale</label>
            <select class="input-field !w-auto !py-3 !px-4" id="score-scale" data-score-scale>
              <option value="5">1-5</option>
              <option value="10" selected>1-10</option>
              <option value="20">1-20</option>
              <option value="100">1-100</option>
            </select>
          </div>
        </div>

        <form class="space-y-4" data-rubric-form>
          <div class="space-y-4" data-rubric-rows></div>
          <div class="flex flex-col gap-4 pt-2 md:flex-row md:items-center md:justify-between">
            <button class="btn-ghost !px-5 !py-3 !text-sm" type="button" data-add-criterion>+ Add criterion</button>
            <div class="flex items-center gap-4">
              <span class="status-pill hidden !bg-transparent !border-none !p-0" data-rubric-status></span>
              <button class="btn-primary !px-8" type="submit">Save rubric</button>
            </div>
          </div>
        </form>
      </section>

      <section class="card !p-8 space-y-8">
        <div class="space-y-3">
          <span class="eyebrow !text-violet !bg-violet/10 !border-violet/20">Judge Access</span>
          <h2 class="section-title !mb-0 mt-4 text-4xl">Shared links</h2>
          <p class="text-cream/50 leading-relaxed">
            Create revocable judge links with optional PIN protection and finite expiry.
          </p>
        </div>

        <form class="space-y-5" data-judge-link-form>
          <div class="space-y-2">
            <label class="form-label" for="judge-label">Label</label>
            <input class="input-field" id="judge-label" name="label" placeholder="Design judge / sponsor reviewer" />
          </div>
          <div class="space-y-2">
            <label class="form-label" for="judge-expires-at">Expires at</label>
            <input class="input-field" id="judge-expires-at" name="expiresAt" type="datetime-local" required />
          </div>
          <div class="space-y-2">
            <label class="form-label" for="judge-pin">Optional PIN</label>
            <input class="input-field" id="judge-pin" name="pin" type="text" inputmode="numeric" autocomplete="off" placeholder="1234" />
          </div>
          <div class="flex items-center justify-between gap-4">
            <span class="status-pill hidden !bg-transparent !border-none !p-0" data-link-status></span>
            <button class="btn-primary !px-6" type="submit">Generate link</button>
          </div>
        </form>

        <div class="hidden space-y-4 rounded-3xl border border-lime/20 bg-lime/5 p-5" data-generated-link-wrap>
          <p class="text-xs font-bold uppercase tracking-widest text-lime">New judge link</p>
          <div class="flex flex-col gap-3 md:flex-row md:items-center">
            <input class="input-field flex-1 font-mono text-xs" readonly data-generated-link />
            <button class="btn-ghost !px-4 !py-3 !text-sm" type="button" data-copy-link>Copy</button>
          </div>
        </div>

        <div class="space-y-4">
          <h3 class="text-sm font-bold uppercase tracking-widest text-cream/40">Existing links</h3>
          <div class="space-y-3" data-judge-links>
            <div class="text-sm text-cream/35 italic">No judge links loaded yet.</div>
          </div>
        </div>
      </section>
    </div>

    <section class="card !p-8 mt-8 space-y-6">
      <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
        <div>
          <span class="eyebrow !text-sky !bg-sky/10 !border-sky/20">Scoreboard</span>
          <h2 class="section-title !mb-0 mt-4 text-4xl">Ranked submissions</h2>
        </div>
        <span class="status-pill hidden" data-overview-status></span>
      </div>
      <div class="overflow-x-auto">
        <table class="min-w-full text-left text-sm">
          <thead class="text-xs uppercase tracking-widest text-cream/35">
            <tr>
              <th class="pb-4 pr-4">Rank</th>
              <th class="pb-4 pr-4">Project</th>
              <th class="pb-4 pr-4">Track</th>
              <th class="pb-4 pr-4">Team</th>
              <th class="pb-4 pr-4">Score</th>
              <th class="pb-4 pr-4">Votes</th>
              <th class="pb-4">Status</th>
            </tr>
          </thead>
          <tbody class="align-top divide-y divide-white/5" data-overview-rows>
            <tr>
              <td colspan="7" class="py-8 text-cream/35 italic">Waiting for judging data...</td>
            </tr>
          </tbody>
        </table>
      </div>
    </section>

    <section class="grid gap-8 xl:grid-cols-2 mt-8">
      <section class="card !p-8 space-y-6">
        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="eyebrow !text-coral !bg-coral/10 !border-coral/20">Tie Breaks</span>
            <h2 class="section-title !mb-0 mt-4 text-4xl">Manual resolution</h2>
          </div>
          <span class="status-pill hidden" data-tie-status></span>
        </div>
        <div class="space-y-4" data-tie-breaks>
          <div class="text-sm text-cream/35 italic">No unresolved ties yet.</div>
        </div>
      </section>

      <section class="card !p-8 space-y-6">
        <div class="flex flex-col gap-3 md:flex-row md:items-end md:justify-between">
          <div>
            <span class="eyebrow !text-lime !bg-lime/10 !border-lime/20">Winners</span>
            <h2 class="section-title !mb-0 mt-4 text-4xl">Publishable results</h2>
          </div>
          <span class="status-pill hidden" data-winner-status></span>
        </div>

        <form class="space-y-6" data-winners-form>
          <div class="space-y-2">
            <label class="form-label" for="overall-winner">Overall winner</label>
            <select class="input-field" id="overall-winner" name="overallWinnerId" data-overall-winner>
              <option value="">Select a submission</option>
            </select>
          </div>
          <div class="space-y-4" data-track-winners>
            <div class="text-sm text-cream/35 italic">Track winner selectors will appear here once tracks load.</div>
          </div>
          <div class="space-y-2">
            <label class="form-label" for="winner-notes">Tie-break notes</label>
            <textarea class="input-field" id="winner-notes" name="notes" rows="4" placeholder="Record any manual tie-break rationale before publishing."></textarea>
          </div>
          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <p class="text-sm text-cream/40">Winners should be selected before results are published.</p>
            <button class="btn-primary !px-8" type="submit">Save winners</button>
          </div>
        </form>
      </section>
    </section>
  </div>

  <script define:vars={{ eventId }}>
    const baseApi = `/api/organizer/events/${eventId}`;
    const publicLinkBase = `/events/`;

    const $ = (selector) => document.querySelector(selector);
    const escapeHtml = (value) => String(value ?? '')
      .replace(/&/g, '&amp;')
      .replace(/</g, '&lt;')
      .replace(/>/g, '&gt;')
      .replace(/"/g, '&quot;')
      .replace(/'/g, '&#39;');
    const toList = (value) => (Array.isArray(value) ? value : []);
    const formatDate = (value) => {
      if (!value) return 'TBD';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return String(value);
      return new Intl.DateTimeFormat(undefined, { month: 'short', day: 'numeric', year: 'numeric', hour: 'numeric', minute: '2-digit' }).format(date);
    };
    const formatDateForInput = (value) => {
      if (!value) return '';
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return '';
      const offset = date.getTimezoneOffset() * 60000;
      return new Date(date.getTime() - offset).toISOString().slice(0, 16);
    };
    const setStatus = (el, message, tone = '') => {
      if (!el) return;
      if (!message) {
        el.textContent = '';
        el.classList.add('hidden');
        el.classList.remove('!text-lime', '!text-coral', '!text-sky');
        return;
      }
      el.textContent = message;
      el.classList.remove('hidden', '!text-lime', '!text-coral', '!text-sky');
      if (tone) el.classList.add(tone);
    };

    const elements = {
      title: $('[data-event-title]'),
      publicLink: $('[data-public-link]'),
      publishBtn: $('[data-publish-results]'),
      statCriteria: $('[data-stat-criteria]'),
      statJudgeLinks: $('[data-stat-judge-links]'),
      statTies: $('[data-stat-ties]'),
      statResults: $('[data-stat-results]'),
      rubricForm: $('[data-rubric-form]'),
      rubricRows: $('[data-rubric-rows]'),
      rubricScale: $('[data-score-scale]'),
      rubricStatus: $('[data-rubric-status]'),
      addCriterion: $('[data-add-criterion]'),
      judgeLinkForm: $('[data-judge-link-form]'),
      linkStatus: $('[data-link-status]'),
      generatedLinkWrap: $('[data-generated-link-wrap]'),
      generatedLink: $('[data-generated-link]'),
      copyLink: $('[data-copy-link]'),
      judgeLinks: $('[data-judge-links]'),
      overviewRows: $('[data-overview-rows]'),
      overviewStatus: $('[data-overview-status]'),
      tieBreaks: $('[data-tie-breaks]'),
      tieStatus: $('[data-tie-status]'),
      winnersForm: $('[data-winners-form]'),
      overallWinner: $('[data-overall-winner]'),
      trackWinners: $('[data-track-winners]'),
      winnerStatus: $('[data-winner-status]')
    };

    const state = {
      event: null,
      rubricMeta: null,
      rubric: [],
      judgeLinks: [],
      submissions: [],
      tracks: [],
      overallRanking: [],
      rankingByTrack: new Map(),
      unresolvedTies: [],
      winners: {
        overallWinnerId: "",
        trackWinners: {}
      },
      published: false
    };

    const criterionRow = (criterion = {}) => `
      <div class="card !p-6 border-white/10 bg-white/[0.03]" data-criterion-row>
        <div class="grid gap-4 md:grid-cols-[1fr_160px_auto] items-end">
          <div class="space-y-2">
            <label class="form-label">Criterion name</label>
            <input class="input-field" name="criterionName" value="${escapeHtml(criterion.name || '')}" placeholder="Originality" />
          </div>
          <div class="space-y-2">
            <label class="form-label">Weight</label>
            <input class="input-field" name="criterionWeight" type="number" min="0" step="0.1" value="${escapeHtml(criterion.weight ?? 1)}" />
          </div>
          <button class="w-10 h-10 rounded-full bg-white/5 flex items-center justify-center hover:bg-coral/20 hover:text-coral transition-all" type="button" data-remove-criterion aria-label="Remove criterion">
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        </div>
      </div>
    `;

    const apiJson = async (url, options = {}, statusEl = null) => {
      try {
        setStatus(statusEl, 'Saving...', '!text-sky');
        const response = await fetch(url, {
          headers: { 'content-type': 'application/json', ...(options.headers || {}) },
          ...options
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || `Request failed (${response.status})`);
        setStatus(statusEl, payload.message || 'Saved', '!text-lime');
        return payload;
      } catch (error) {
        setStatus(statusEl, error.message, '!text-coral');
        throw error;
      }
    };

    const renderRubric = () => {
      if (!elements.rubricRows) return;
      const rows = state.rubric.length ? state.rubric : [{ name: 'Impact', weight: 1 }, { name: 'Execution', weight: 1 }];
      elements.rubricRows.innerHTML = rows.map((criterion) => criterionRow(criterion)).join('');
      if (elements.rubricScale) elements.rubricScale.value = String(state.rubricMeta?.maxScore || 10);
      elements.rubricRows.querySelectorAll('[data-remove-criterion]').forEach((button) => {
        button.addEventListener('click', () => button.closest('[data-criterion-row]')?.remove());
      });
    };

    const renderJudgeLinks = () => {
      if (!elements.judgeLinks) return;
      const links = toList(state.judgeLinks);
      if (!links.length) {
        elements.judgeLinks.innerHTML = '<div class="text-sm text-cream/35 italic">No judge links yet.</div>';
        return;
      }
      const now = Date.now();
      elements.judgeLinks.innerHTML = links.map((link) => `
        <div class="card !p-5 border-white/10 bg-white/[0.03]">
          <div class="flex flex-col gap-4">
            <div class="flex flex-wrap items-center justify-between gap-3">
              <div class="space-y-1">
                <p class="font-bold">${escapeHtml(link.label || 'Judge link')}</p>
                <p class="text-xs text-cream/40">${escapeHtml(link.id || '')}</p>
              </div>
              <span class="status-pill ${
                link.revokedAt
                  ? '!bg-coral/10 !text-coral !border-coral/20'
                  : (new Date(link.expiresAt).getTime() < now)
                    ? '!bg-sky/10 !text-sky !border-sky/20'
                    : '!bg-lime/10 !text-lime !border-lime/20'
              }">
                ${link.revokedAt ? 'Revoked' : (new Date(link.expiresAt).getTime() < now) ? 'Expired' : 'Active'}
              </span>
            </div>
            <div class="text-sm text-cream/45">
              Expires ${escapeHtml(formatDate(link.expiresAt))}
              ${Number(link.hasPin) ? ' · PIN protected' : ''}
            </div>
            <div class="flex items-center justify-between gap-3">
              <span class="text-xs text-cream/35">${escapeHtml(formatDate(link.createdAt))}</span>
              ${!link.revokedAt ? `<button class="btn-ghost !px-4 !py-2 !text-xs" type="button" data-revoke-link data-link-id="${escapeHtml(link.id)}">Revoke</button>` : ''}
            </div>
          </div>
        </div>
      `).join('');
      elements.judgeLinks.querySelectorAll('[data-revoke-link]').forEach((button) => {
        button.addEventListener('click', async () => {
          const linkId = button.getAttribute('data-link-id');
          if (!linkId) return;
          await apiJson(`${baseApi}/judge-links/${linkId}/revoke`, { method: 'POST' }, elements.linkStatus);
          await loadWorkspace();
        });
      });
    };

    const renderOverview = () => {
      if (!elements.overviewRows) return;
      const rankings = toList(state.overallRanking);
      if (!rankings.length) {
        elements.overviewRows.innerHTML = '<tr><td colspan="7" class="py-8 text-cream/35 italic">No submissions scored yet.</td></tr>';
        return;
      }
      elements.overviewRows.innerHTML = rankings.map((row, index) => `
        <tr class="${row.hasTie ? 'bg-coral/5' : ''}">
          <td class="py-4 pr-4 font-bold">${escapeHtml(row.rank ?? index + 1)}</td>
          <td class="py-4 pr-4">
            <div class="font-bold">${escapeHtml(row.projectName || row.project_name || 'Untitled project')}</div>
            <div class="text-xs text-cream/40">${escapeHtml(row.description || '')}</div>
          </td>
          <td class="py-4 pr-4">${escapeHtml(row.track || 'All tracks')}</td>
          <td class="py-4 pr-4">${escapeHtml(row.teamName || row.team_name || '')}</td>
          <td class="py-4 pr-4"><span class="status-pill !bg-white/5 !border-white/10">${escapeHtml(row.totalScore ?? row.score ?? '0')}</span></td>
          <td class="py-4 pr-4">${escapeHtml(row.voteCount ?? row.votes ?? 0)}</td>
          <td class="py-4">
            <div class="flex flex-wrap gap-2">
              ${row.isWinner ? '<span class="status-pill !bg-lime/10 !text-lime !border-lime/20">Winner</span>' : ''}
              ${row.hasTie ? '<span class="status-pill !bg-coral/10 !text-coral !border-coral/20">Tie</span>' : ''}
              ${row.popularityBadge ? `<span class="status-pill !bg-sky/10 !text-sky !border-sky/20">${escapeHtml(row.popularityBadge)}</span>` : ''}
            </div>
          </td>
        </tr>
      `).join('');
    };

    const renderTieBreaks = () => {
      if (!elements.tieBreaks) return;
      const ties = toList(state.unresolvedTies);
      setStatus(elements.tieStatus, ties.length ? `${ties.length} unresolved` : 'All clear', ties.length ? '!text-coral' : '!text-lime');
      if (!ties.length) {
        elements.tieBreaks.innerHTML = '<div class="text-sm text-cream/35 italic">No unresolved ties yet.</div>';
        return;
      }
      elements.tieBreaks.innerHTML = ties.map((tie, index) => `
        <div
          class="card !p-5 border-coral/15 bg-coral/5 space-y-4"
          data-tie-row
          data-scope="${escapeHtml(tie.scope || "overall")}"
          data-track-name="${escapeHtml(tie.trackName || "")}"
          data-tie-id="${escapeHtml(tie.id || index)}"
        >
          <div class="flex items-center justify-between gap-3">
            <div>
              <p class="font-bold">${escapeHtml(tie.scope === "track" ? `Track tie: ${tie.trackName}` : `Overall tie`)}</p>
              <p class="text-xs text-cream/40">${escapeHtml(tie.description || '')}</p>
            </div>
            <span class="status-pill !bg-coral/10 !text-coral !border-coral/20">${escapeHtml(toList(tie.tiedSubmissionIds || tie.submissions || tie.submissionIds).length)} projects</span>
          </div>
          <div class="grid gap-3">
            ${toList(tie.tiedSubmissionIds || tie.submissions || tie.submissionIds).map((submissionId) => {
              const submission = state.submissions.find((item) => String(item.id) === String(submissionId)) || {};
              return `
                <label class="flex items-center gap-3 rounded-2xl border border-white/10 bg-white/[0.03] px-4 py-3">
                  <input type="radio" name="tie-${escapeHtml(tie.id || index)}" value="${escapeHtml(submission.id || submissionId)}" class="accent-lime" ${tie.resolvedWinnerId === submission.id ? 'checked' : ''} />
                  <span class="font-medium">${escapeHtml(submission.projectName || submission.project_name || submission.teamName || submission.team_name || submissionId)}</span>
                </label>
              `;
            }).join('')}
          </div>
        </div>
      `).join('');

      elements.tieBreaks.querySelectorAll("[data-tie-row] input[type='radio']").forEach((input) => {
        input.addEventListener("change", () => {
          const row = input.closest("[data-tie-row]");
          const scope = row?.getAttribute("data-scope") || "overall";
          const trackName = row?.getAttribute("data-track-name") || "";
          if (scope === "overall" && elements.overallWinner) {
            elements.overallWinner.value = input.value;
          } else {
            const select = elements.trackWinners?.querySelector(
              `[data-track-winner][data-track-name="${CSS.escape(trackName)}"]`
            );
            if (select) select.value = input.value;
          }
        });
      });
    };

    const renderWinnerControls = () => {
      if (!elements.overallWinner || !elements.trackWinners) return;
      const submissions = toList(state.submissions);
      elements.overallWinner.innerHTML = ['<option value="">Select a submission</option>', ...submissions.map((submission) => `<option value="${escapeHtml(submission.id)}">${escapeHtml(submission.projectName || submission.teamName || submission.id)}</option>`)].join('');
      if (state.winners.overallWinnerId) elements.overallWinner.value = String(state.winners.overallWinnerId);
      const tracks = toList(state.tracks);
      if (!tracks.length) {
        elements.trackWinners.innerHTML = '<div class="text-sm text-cream/35 italic">No tracks configured for this event.</div>';
        return;
      }
      elements.trackWinners.innerHTML = tracks.map((track) => `
        <div class="space-y-2">
          <label class="form-label" for="track-winner-${escapeHtml(track.name)}">${escapeHtml(track.name)}</label>
          <select class="input-field" id="track-winner-${escapeHtml(track.name)}" data-track-winner data-track-name="${escapeHtml(track.name)}">
            <option value="">Select a submission</option>
            ${submissions.map((submission) => `<option value="${escapeHtml(submission.id)}">${escapeHtml(submission.projectName || submission.teamName || submission.id)}</option>`).join('')}
          </select>
        </div>
      `).join('');
      elements.trackWinners.querySelectorAll('[data-track-winner]').forEach((select) => {
        const trackName = select.getAttribute('data-track-name');
        const winnerId = state.winners.trackWinners?.[trackName];
        if (winnerId) select.value = String(winnerId);
      });
    };

    const syncStats = () => {
      if (elements.statCriteria) elements.statCriteria.textContent = String(toList(state.rubric).length);
      if (elements.statJudgeLinks) elements.statJudgeLinks.textContent = String(toList(state.judgeLinks).length);
      if (elements.statTies) elements.statTies.textContent = String(toList(state.unresolvedTies).length);
      if (elements.statResults) elements.statResults.textContent = state.published ? 'Published' : 'Draft';
      setStatus(elements.overviewStatus, state.published ? 'Results published' : 'Draft only', state.published ? '!text-lime' : '!text-sky');
    };

    const renderWorkspace = () => {
      if (elements.title && state.event) elements.title.textContent = state.event.title || 'Judging workspace';
      if (elements.publicLink && state.event?.slug) elements.publicLink.href = `${publicLinkBase}${state.event.slug}`;
      renderRubric();
      renderJudgeLinks();
      renderOverview();
      renderTieBreaks();
      renderWinnerControls();
      syncStats();
    };

    const readRubric = () => ({
      minScore: 1,
      maxScore: Number(elements.rubricScale?.value || 10),
      title: state.rubricMeta?.title || "Judging Rubric",
      description: state.rubricMeta?.description || "",
      criteria: Array.from(elements.rubricRows?.querySelectorAll('[data-criterion-row]') || []).map((row) => ({
        name: row.querySelector('[name="criterionName"]')?.value?.trim() || '',
        weight: row.querySelector('[name="criterionWeight"]')?.value?.trim() || ''
      })).filter((criterion) => criterion.name)
    });

    const readWinnerPayload = () => ({
      overallWinnerSubmissionId: elements.overallWinner?.value || '',
      trackWinners: Array.from(elements.trackWinners?.querySelectorAll('[data-track-winner]') || [])
        .map((select) => ({
          trackName: select.getAttribute("data-track-name") || "",
          submissionId: select.value || ""
        }))
        .filter((row) => row.trackName && row.submissionId),
      note: elements.winnersForm?.querySelector('[name="notes"]')?.value || ''
    });

    const loadWorkspace = async () => {
      if (!eventId) return;
      try {
        const [eventRes, rubricRes, linksRes, overviewRes] = await Promise.all([
          fetch(`${baseApi}`),
          fetch(`${baseApi}/rubric`),
          fetch(`${baseApi}/judge-links`),
          fetch(`${baseApi}/judging-overview`)
        ]);

        if (eventRes.status === 401) {
          window.location.href = '/organizer/login';
          return;
        }

        const eventPayload = await eventRes.json().catch(() => ({}));
        const rubricPayload = await rubricRes.json().catch(() => ({}));
        const linksPayload = await linksRes.json().catch(() => ({}));
        const overviewPayload = await overviewRes.json().catch(() => ({}));

        if (!eventRes.ok) throw new Error(eventPayload.error || "Unable to load event.");
        if (!rubricRes.ok) throw new Error(rubricPayload.error || "Unable to load rubric.");
        if (!linksRes.ok) throw new Error(linksPayload.error || "Unable to load judge links.");
        if (!overviewRes.ok) throw new Error(overviewPayload.error || "Unable to load judging overview.");

        state.event = eventPayload.event || null;
        state.tracks = toList(eventPayload.tracks);
        state.rubricMeta = rubricPayload.rubric || null;
        state.rubric = toList(rubricPayload.criteria);
        state.judgeLinks = toList(linksPayload.links);
        state.submissions = toList(overviewPayload.submissions);
        state.overallRanking = toList(overviewPayload.rankings?.overall?.ranking).map((row, index) => ({
          ...row,
          rank: index + 1
        }));
        state.rankingByTrack = new Map(
          toList(overviewPayload.rankings?.tracks).map((track) => [track.trackName, toList(track.ranking)])
        );
        state.unresolvedTies = toList(overviewPayload.unresolvedTies);
        state.published = overviewPayload.event?.resultsStatus === "published";

        const winners = toList(overviewPayload.winners);
        const overallWinner = winners.find((winner) => winner.scope === "overall");
        const trackWinners = winners.filter((winner) => winner.scope === "track");
        state.winners = {
          overallWinnerId: overallWinner?.submissionId || "",
          trackWinners: Object.fromEntries(trackWinners.map((winner) => [winner.trackName, winner.submissionId]))
        };

        const winnerIds = new Set(winners.map((winner) => winner.submissionId));
        state.overallRanking = state.overallRanking.map((row) => ({
          ...row,
          isWinner: winnerIds.has(row.id),
          hasTie: state.unresolvedTies.some((tie) =>
            toList(tie.tiedSubmissionIds).includes(row.id)
          )
        }));

        if (elements.rubricScale) {
          elements.rubricScale.value = String(rubricPayload.rubric?.maxScore || 10);
        }
        renderWorkspace();
      } catch (error) {
        setStatus(elements.overviewStatus, error.message, '!text-coral');
      }
    };

    elements.addCriterion?.addEventListener('click', () => {
      elements.rubricRows?.insertAdjacentHTML('beforeend', criterionRow({}));
    });

    elements.rubricForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      await apiJson(`${baseApi}/rubric`, { method: 'PUT', body: JSON.stringify(readRubric()) }, elements.rubricStatus);
      await loadWorkspace();
    });

    elements.judgeLinkForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      const formData = new FormData(event.currentTarget);
      const payload = {
        label: String(formData.get('label') || '').trim(),
        expiresAt: String(formData.get('expiresAt') || '').trim(),
        pin: String(formData.get('pin') || '').trim()
      };
      const result = await apiJson(`${baseApi}/judge-links`, { method: 'POST', body: JSON.stringify(payload) }, elements.linkStatus);
      const generatedToken = result.link?.token || "";
      const generated = generatedToken ? `${window.location.origin}/judge/${generatedToken}` : "";
      if (generated && elements.generatedLinkWrap && elements.generatedLink) {
        elements.generatedLink.value = generated;
        elements.generatedLinkWrap.classList.remove('hidden');
      }
      await loadWorkspace();
    });

    elements.copyLink?.addEventListener('click', async () => {
      const value = elements.generatedLink?.value || '';
      if (!value) return;
      try {
        await navigator.clipboard.writeText(value);
        setStatus(elements.linkStatus, 'Copied link', '!text-lime');
      } catch {
        setStatus(elements.linkStatus, 'Copy failed', '!text-coral');
      }
    });

    elements.winnersForm?.addEventListener('submit', async (event) => {
      event.preventDefault();
      await apiJson(`${baseApi}/winners`, { method: 'PUT', body: JSON.stringify(readWinnerPayload()) }, elements.winnerStatus);
      await loadWorkspace();
    });

    elements.publishBtn?.addEventListener('click', async () => {
      await apiJson(`${baseApi}/publish-results`, { method: 'POST' }, elements.winnerStatus);
      await loadWorkspace();
    });

    if (elements.judgeLinkForm) {
      const expiresField = elements.judgeLinkForm.querySelector('[name="expiresAt"]');
      if (expiresField && !expiresField.value) {
        const defaultExpiry = new Date(Date.now() + 14 * 24 * 60 * 60 * 1000);
        expiresField.value = formatDateForInput(defaultExpiry.toISOString());
      }
    }

    loadWorkspace();
  </script>
</BaseLayout>
