---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import EventJudgingPanel from "../../../../components/organizer/EventJudgingPanel.astro";

const eventId = Astro.params.id ? String(Astro.params.id) : "";
---

<BaseLayout title="Judging | Hatch">
  <div class="mx-auto max-w-7xl px-6 py-12">
    <div class="mb-10 flex flex-col gap-6 xl:flex-row xl:items-end xl:justify-between">
      <div class="space-y-4">
        <div class="flex items-center gap-3">
          <a
            href={`/organizer/events/${eventId}`}
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-cream/5 transition-colors hover:bg-cream/10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </a>
          <span class="eyebrow !border-lime/20 !bg-lime/10 !text-lime">Judging workspace</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tighter md:text-5xl">Judging workspace</h1>
        <p class="max-w-3xl leading-relaxed text-cream/50">
          Same tools as the Judging tab on the event editor. Use this page when you want more room.
        </p>
      </div>
    </div>

    {eventId ? <EventJudgingPanel eventId={eventId} showStandaloneLink={false} /> : null}
  </div>

  <script>
    import { initJudgingWorkspace } from "../../../../lib/client/judging-workspace";

    const root = document.querySelector("[data-judging-root]");
    const id = root?.getAttribute("data-judging-event-id")?.trim() || "";
    if (root && id) {
      initJudgingWorkspace(root, id);
    }
  </script>
</BaseLayout>
