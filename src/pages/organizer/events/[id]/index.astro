---
import BaseLayout from "../../../../layouts/BaseLayout.astro";
import EventJudgingPanel from "../../../../components/organizer/EventJudgingPanel.astro";

const rawEditorId = Astro.params.id;
const editorEventId = rawEditorId && rawEditorId !== "new" ? String(rawEditorId) : "";
---

<BaseLayout title="Manage Event | Hatch">
  <div class="mx-auto max-w-6xl px-6 py-12">
    {/* Page Header */}
    <div class="flex flex-col md:flex-row md:items-end justify-between gap-8 mb-12">
      <div class="space-y-4">
        <div class="flex items-center gap-3">
            <a href="/organizer/dashboard" class="w-8 h-8 rounded-lg bg-cream/5 flex items-center justify-center hover:bg-cream/10 transition-colors">
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
            </a>
            <span class="eyebrow !text-sky !bg-sky/10 !border-sky/20">Event editor</span>
        </div>
        <h1 class="text-4xl md:text-5xl font-bold tracking-tighter" data-event-title>Loading Event...</h1>
        <p class="text-cream/50 max-w-2xl leading-relaxed" data-page-subtitle>Update event details, tracks, FAQ, judging, and exports in one place.</p>
      </div>
      <div class="flex items-center gap-4">
          <a class="btn-ghost !px-6" data-public-link href="#" target="_blank">
             <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="mr-2 opacity-60"><path d="M18 13v6a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h6"/><polyline points="15 3 21 3 21 9"/><line x1="10" y1="14" x2="21" y2="3"/></svg>
             Public page
          </a>
          <span class="status-pill hidden !bg-transparent !border-none !p-0" data-status role="status" aria-live="polite"></span>
          <button class="btn-primary !px-10" id="save-btn-top" type="submit" form="event-config-form">Save changes</button>
      </div>
    </div>

    <form class="space-y-12" data-event-form id="event-config-form">
      <div class="card !p-0 overflow-hidden border-cream/10 bg-cream/[0.02]" data-tabs>
        <div class="flex flex-wrap items-center justify-between gap-4 border-b border-cream/10 px-5 py-4">
          <div class="flex flex-wrap items-center gap-3">
            <span class="status-pill !text-[10px] !py-1 !px-3 !uppercase !tracking-[0.2em] !bg-coral/10 !text-coral !border-coral/20" data-editor-status>
              Draft
            </span>
            <span class="text-xs uppercase tracking-widest text-cream/45" data-editor-health>Checking sections...</span>
          </div>
          <div class="text-[11px] uppercase tracking-widest text-cream/40">
            <span class="inline-flex items-center gap-2">
              <span class="h-2 w-2 rounded-full bg-coral" aria-hidden="true"></span>
              red dot = needs work
            </span>
          </div>
        </div>
        <div class="flex flex-wrap gap-2 px-4 py-3">
          <button class="btn-ghost !px-4 !py-2 !text-xs uppercase tracking-widest" type="button" data-tab-btn data-tab-id="core">
            <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-coral/90" data-tab-dot data-tab-dot-id="core"></span>Core</span>
          </button>
          <button class="btn-ghost !px-4 !py-2 !text-xs uppercase tracking-widest" type="button" data-tab-btn data-tab-id="logistics">
            <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-coral/90" data-tab-dot data-tab-dot-id="logistics"></span>Logistics</span>
          </button>
          <button class="btn-ghost !px-4 !py-2 !text-xs uppercase tracking-widest" type="button" data-tab-btn data-tab-id="tracks">
            <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-coral/90" data-tab-dot data-tab-dot-id="tracks"></span>Tracks</span>
          </button>
          <button class="btn-ghost !px-4 !py-2 !text-xs uppercase tracking-widest" type="button" data-tab-btn data-tab-id="faq">
            <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-coral/90" data-tab-dot data-tab-dot-id="faq"></span>FAQ</span>
          </button>
          <button class="btn-ghost !px-4 !py-2 !text-xs uppercase tracking-widest" type="button" data-tab-btn data-tab-id="applications">
            <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-coral/90" data-tab-dot data-tab-dot-id="applications"></span>Applications</span>
          </button>
          <button class="btn-ghost !px-4 !py-2 !text-xs uppercase tracking-widest" type="button" data-tab-btn data-tab-id="judging" data-existing-only>
            <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-coral/90" data-tab-dot data-tab-dot-id="judging"></span>Judging</span>
          </button>
          <button class="btn-ghost !px-4 !py-2 !text-xs uppercase tracking-widest" type="button" data-tab-btn data-tab-id="exports">
            <span class="inline-flex items-center gap-2"><span class="h-2 w-2 rounded-full bg-coral/90" data-tab-dot data-tab-dot-id="exports"></span>Exports</span>
          </button>
        </div>
      </div>

      {/* 1. Core Identity */}
      <section class="space-y-8" data-tab-section data-tab-id="core">
        <div class="flex items-center gap-4 mb-2">
            <span class="w-8 h-8 rounded-lg bg-violet/10 text-violet flex items-center justify-center font-bold text-xs border border-violet/20">01</span>
            <h2 class="text-2xl font-bold tracking-tight">Core Identity</h2>
        </div>
        <div class="card !p-10 grid md:grid-cols-2 gap-10 border-cream/10 bg-cream/[0.02]">
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Event Title *</label>
                    <input class="input-field" name="title" required placeholder="Technosphere 2026" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">URL slug *</label>
                    <input class="input-field" name="slug" required placeholder="technosphere-2026" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Tagline</label>
                    <input class="input-field" name="tagline" placeholder="Bending reality with code..." />
                </div>
            </div>
            <div class="space-y-2">
                <label class="form-label">Description</label>
                <textarea class="input-field !h-[calc(100%-2rem)]" name="description" placeholder="Tell the world about your mission..."></textarea>
            </div>
            <div class="space-y-3 md:col-span-2">
                <label class="form-label">Banner image</label>
                <input
                  class="input-field"
                  name="bannerUrl"
                  type="text"
                  inputmode="url"
                  autocomplete="off"
                  placeholder="https://... or upload below"
                  data-edit-banner-url
                />
                <p class="text-xs text-cream/35 leading-relaxed">
                  HTTPS link or upload (JPEG, PNG, WebP, GIF, max 5&nbsp;MB). Shown on the public event page.
                </p>
                <div class="flex flex-col gap-3 sm:flex-row sm:items-center">
                  <label class="inline-flex cursor-pointer items-center justify-center rounded-2xl border border-dashed border-cream/20 bg-cream/[0.04] px-5 py-3 text-sm font-medium text-cream/80 transition-colors hover:border-lime/35 hover:bg-cream/[0.07]">
                    <input
                      type="file"
                      class="sr-only"
                      accept="image/jpeg,image/png,image/webp,image/gif,.jpg,.jpeg,.png,.webp,.gif"
                      data-edit-banner-file
                    />
                    <span>Choose image to upload</span>
                  </label>
                  <span class="text-xs text-cream/35" data-edit-banner-upload-status></span>
                </div>
            </div>
        </div>
      </section>

      {/* 2. Logistics & Parameters */}
      <section class="space-y-8" data-tab-section data-tab-id="logistics">
        <div class="flex items-center gap-4 mb-2">
            <span class="w-8 h-8 rounded-lg bg-sky/10 text-sky flex items-center justify-center font-bold text-xs border border-sky/20">02</span>
            <h2 class="text-2xl font-bold tracking-tight">Schedule and logistics</h2>
        </div>
        <div class="card !p-10 grid md:grid-cols-2 lg:grid-cols-3 gap-10 border-cream/10 bg-cream/[0.02]">
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Start date and time *</label>
                    <input class="input-field" name="startDate" type="datetime-local" required />
                </div>
                <div class="space-y-2">
                    <label class="form-label">End date and time *</label>
                    <input class="input-field" name="endDate" type="datetime-local" required />
                </div>
            </div>
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Location</label>
                    <input class="input-field" name="location" placeholder="San Francisco / Global" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Participant location options</label>
                    <textarea
                      class="input-field min-h-[8.5rem]"
                      name="participantLocations"
                      placeholder="San Francisco&#10;New York City&#10;Online"
                    ></textarea>
                    <p class="text-xs leading-relaxed text-cream/35">
                      One option per line. Applicants will choose from this dropdown when they register.
                    </p>
                </div>
                <div class="space-y-2">
                    <label class="form-label">Format</label>
                    <select class="input-field" name="mode">
                        <option>Hybrid</option>
                        <option>In-person</option>
                        <option>Online</option>
                    </select>
                </div>
            </div>
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Organization name</label>
                    <input class="input-field" name="organizationName" placeholder="e.g. Major League Hacking" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Website</label>
                    <input class="input-field" name="websiteUrl" placeholder="https://hackathon.com" />
                </div>
            </div>
            <div class="grid grid-cols-2 gap-6">
                <div class="space-y-2">
                    <label class="form-label">Twitter/X</label>
                    <input class="input-field" name="twitterUrl" placeholder="https://x.com/handle" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Discord</label>
                    <input class="input-field" name="discordUrl" placeholder="https://discord.gg/invitelink" />
                </div>
            </div>
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Participant capacity</label>
                    <input class="input-field" name="maxParticipants" type="number" placeholder="e.g. 500" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Application deadline</label>
                    <input class="input-field" name="applicationDeadline" type="datetime-local" />
                </div>
                <div class="space-y-3 pt-8">
                    <p class="form-label text-center">Publish status</p>
                    <label class="mx-auto inline-flex cursor-pointer items-center gap-3 select-none" for="isPublishedSwitch">
                        <span class="relative inline-flex h-7 w-12 items-center rounded-full border border-cream/10 bg-cream/5 transition-colors hover:border-lime/30">
                            <input
                              id="isPublishedSwitch"
                              type="checkbox"
                              name="isPublished"
                              class="peer absolute inset-0 h-full w-full cursor-pointer opacity-0"
                            />
                            <span class="pointer-events-none h-5 w-5 translate-x-1 rounded-full bg-cream/20 transition-all peer-checked:translate-x-6 peer-checked:bg-lime"></span>
                        </span>
                        <span class="text-sm font-bold text-cream/60">Published</span>
                    </label>
                </div>
            </div>
        </div>
      </section>

      {/* 3. Specialized Tracks */}
      <section class="space-y-8" data-tab-section data-tab-id="tracks">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <span class="w-8 h-8 rounded-lg bg-lime/10 text-lime flex items-center justify-center font-bold text-xs border border-lime/20">03</span>
                <h2 class="text-2xl font-bold tracking-tight">Tracks</h2>
            </div>
            <button class="btn-ghost !py-2 !px-4 !text-xs uppercase tracking-widest hover:border-lime/30 hover:text-lime" type="button" data-add-track>
                + Add Track
            </button>
        </div>
        <div class="grid gap-6" data-tracks></div>
      </section>

      {/* 4. Knowledge Base (FAQ) */}
      <section class="space-y-8" data-tab-section data-tab-id="faq">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <span class="w-8 h-8 rounded-lg bg-coral/10 text-coral flex items-center justify-center font-bold text-xs border border-coral/20">04</span>
                <h2 class="text-2xl font-bold tracking-tight">FAQ</h2>
            </div>
            <button class="btn-ghost !py-2 !px-4 !text-xs uppercase tracking-widest hover:border-coral/30 hover:text-coral" type="button" data-add-faq>
                + Add FAQ
            </button>
        </div>
        <div class="grid gap-4" data-faqs></div>
      </section>

      <section class="space-y-8" data-tab-section data-tab-id="applications">
        <div class="flex items-center justify-between">
            <div class="flex items-center gap-4">
                <span class="w-8 h-8 rounded-lg bg-amber-400/10 text-amber-300 flex items-center justify-center font-bold text-xs border border-amber-300/20">05</span>
                <h2 class="text-2xl font-bold tracking-tight">Applications</h2>
            </div>
            <button class="btn-ghost !py-2 !px-4 !text-xs uppercase tracking-widest hover:border-amber-300/30 hover:text-amber-200" type="button" data-add-application-field>
                + Add Question
            </button>
        </div>
        <div class="space-y-8">
          <div class="card !p-10 border-cream/10 bg-cream/[0.02]">
            <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
              <div class="space-y-3">
                <p class="text-sm leading-relaxed text-cream/55 max-w-3xl">
                  Every application already collects name, email, location, team status, LinkedIn, GitHub, and code-of-conduct consent.
                  Add optional custom questions here so organizers can judge fit more clearly before approving access.
                </p>
                <div class="flex flex-wrap gap-2 text-[11px] uppercase tracking-[0.22em] text-cream/45">
                  <span class="rounded-full border border-cream/10 px-3 py-2">Name</span>
                  <span class="rounded-full border border-cream/10 px-3 py-2">Email</span>
                  <span class="rounded-full border border-cream/10 px-3 py-2">Location</span>
                  <span class="rounded-full border border-cream/10 px-3 py-2">Team status</span>
                  <span class="rounded-full border border-cream/10 px-3 py-2">LinkedIn</span>
                  <span class="rounded-full border border-cream/10 px-3 py-2">GitHub</span>
                </div>
              </div>
            </div>
            <div class="mt-8 grid gap-5" data-application-fields></div>
          </div>

          <div class="card !p-10 border-cream/10 bg-cream/[0.02]" data-existing-only>
            <div class="flex flex-col gap-4 md:flex-row md:items-end md:justify-between">
              <div>
                <p class="text-xs uppercase tracking-[0.22em] text-cream/45">Approval queue</p>
                <h3 class="mt-3 text-2xl font-bold tracking-tight">Review participant applications</h3>
              </div>
              <p class="text-sm text-cream/50" data-applications-summary>Loading applications...</p>
            </div>
            <div class="mt-8 overflow-x-auto">
              <table class="w-full min-w-[980px] text-left text-sm">
                <thead class="border-b border-cream/10 text-[11px] uppercase tracking-[0.22em] text-cream/40">
                  <tr>
                    <th class="pb-4 pr-4 font-medium">Participant</th>
                    <th class="pb-4 pr-4 font-medium">Location</th>
                    <th class="pb-4 pr-4 font-medium">LinkedIn</th>
                    <th class="pb-4 pr-4 font-medium">GitHub</th>
                    <th class="pb-4 pr-4 font-medium">Other details</th>
                    <th class="pb-4 pr-4 font-medium">Status</th>
                    <th class="pb-4 font-medium">Actions</th>
                  </tr>
                </thead>
                <tbody data-applications-body>
                  <tr>
                    <td class="py-6 text-cream/40" colspan="7">Loading applications...</td>
                  </tr>
                </tbody>
              </table>
            </div>
          </div>
        </div>
      </section>

      <button class="hidden" type="submit" data-hidden-submit aria-hidden="true" tabindex="-1">Submit</button>
    </form>

      {/* Judging workspace: must stay outside the main event form — nested <form> tags would implicitly close it in the browser. */}
      {editorEventId ? (
        <section class="space-y-8" data-existing-only data-tab-section data-tab-id="judging">
          <div class="flex items-center gap-4 mb-2">
            <span class="w-8 h-8 rounded-lg bg-violet/10 text-violet flex items-center justify-center font-bold text-xs border border-violet/20">06</span>
            <h2 class="text-2xl font-bold tracking-tight">Judging</h2>
          </div>
          <EventJudgingPanel eventId={editorEventId} />
        </section>
      ) : null}

      {/* 5. Data Export */}
      <section class="space-y-8" data-existing-only data-tab-section data-tab-id="exports">
        <div class="flex items-center gap-4 mb-2">
            <span class="w-8 h-8 rounded-lg bg-cream/10 text-cream flex items-center justify-center font-bold text-xs border border-cream/20">07</span>
            <h2 class="text-2xl font-bold tracking-tight">Exports</h2>
        </div>
        <div class="grid md:grid-cols-2 gap-8">
            <div class="card !p-10 border-cream/10 bg-cream/[0.01] hover:bg-cream/[0.03] transition-all">
                <div class="flex justify-between items-start mb-6">
                    <h3 class="text-xl font-bold">Applications</h3>
                    <div class="w-10 h-10 rounded-full bg-sky/10 flex items-center justify-center text-sky">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    </div>
                </div>
                <p class="text-sm text-cream/40 mb-8 leading-relaxed">Download a comprehensive dataset of all registered participants for external processing.</p>
                <a class="btn-ghost !w-full justify-center !py-4 text-xs font-bold uppercase tracking-widest" data-applications-link href="#">Download CSV</a>
            </div>

            <div class="card !p-10 border-cream/10 bg-cream/[0.01] hover:bg-cream/[0.03] transition-all">
                <div class="flex justify-between items-start mb-6">
                    <h3 class="text-xl font-bold">Submissions</h3>
                    <div class="w-10 h-10 rounded-full bg-violet/10 flex items-center justify-center text-violet">
                        <svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
                    </div>
                </div>
                <p class="text-sm text-cream/40 mb-8 leading-relaxed">Retrieve final project submissions including links, descriptions, and track designations.</p>
                <a class="btn-ghost !w-full justify-center !py-4 text-xs font-bold uppercase tracking-widest" data-submissions-link href="#">Download CSV</a>
            </div>
        </div>
      </section>
  </div>

  <script>
    const pathParts = window.location.pathname.split("/").filter(Boolean);
    const eventId = pathParts[pathParts.length - 1] || "";
    const isCreateMode = eventId === "new";

    const form = document.querySelector("[data-event-form]");
    const status = document.querySelector("[data-status]");
    const titleEl = document.querySelector("[data-event-title]");
    const subtitleEl = document.querySelector("[data-page-subtitle]");
    const tracksContainer = document.querySelector("[data-tracks]");
    const faqsContainer = document.querySelector("[data-faqs]");
    const applicationFieldsContainer = document.querySelector("[data-application-fields]");
    const addApplicationField = document.querySelector("[data-add-application-field]");
    const applicationsBody = document.querySelector("[data-applications-body]");
    const applicationsSummary = document.querySelector("[data-applications-summary]");
    const addTrack = document.querySelector("[data-add-track]");
    const addFaq = document.querySelector("[data-add-faq]");
    const publicLink = document.querySelector("[data-public-link]");
    const applicationsLink = document.querySelector("[data-applications-link]");
    const submissionsLink = document.querySelector("[data-submissions-link]");
    const topSaveBtn = document.querySelector("#save-btn-top");
    const existingOnlyEls = document.querySelectorAll("[data-existing-only]");
    const tabButtons = Array.from(document.querySelectorAll("[data-tab-btn]"));
    const tabSections = Array.from(document.querySelectorAll("[data-tab-section]"));
    const tabDots = Array.from(document.querySelectorAll("[data-tab-dot]"));
    const editorHealth = document.querySelector("[data-editor-health]");
    const editorStatus = document.querySelector("[data-editor-status]");

    const editBannerUrl = form?.querySelector("[data-edit-banner-url]");
    const editBannerFile = form?.querySelector("[data-edit-banner-file]");
    const editBannerUploadStatus = form?.querySelector("[data-edit-banner-upload-status]");

    const titleInput = form?.querySelector("input[name='title']");
    const slugInput = form?.querySelector("input[name='slug']");

    const defaultTopLabel = isCreateMode ? "Create event" : "Save changes";
    const defaultSubmitLabel = isCreateMode ? "Create event" : "Save changes";
    const submitBtn = form?.querySelector("[data-hidden-submit]");
    let currentOrganizerId = "";

    const slugify = (raw) =>
      String(raw || "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const formatForInput = (val) => {
      if (!val) return "";
      const d = new Date(val);
      if (Number.isNaN(d.getTime())) return String(val);
      const offset = d.getTimezoneOffset() * 60000;
      return new Date(d.getTime() - offset).toISOString().slice(0, 16);
    };

    const setStatus = (message, isError = false) => {
      if (!status) return;
      status.textContent = message;
      status.classList.remove("hidden", "!text-coral");
      if (isError) status.classList.add("!text-coral");
    };

    const clearStatus = () => {
      if (!status) return;
      status.textContent = "";
      status.classList.add("hidden");
      status.classList.remove("!text-coral");
    };

    const setButtonsState = (disabled, topLabel, bottomLabel) => {
      if (topSaveBtn) {
        topSaveBtn.disabled = disabled;
        topSaveBtn.textContent = topLabel;
      }
      if (submitBtn) {
        submitBtn.disabled = disabled;
        submitBtn.textContent = bottomLabel;
      }
    };

    const setPublicLink = (slug) => {
      if (!publicLink) return;
      const normalized = String(slug || "").trim();
      if (!normalized) {
        publicLink.href = "#";
        publicLink.classList.add("pointer-events-none", "opacity-50");
        return;
      }
      publicLink.href = currentOrganizerId
        ? `/events/${currentOrganizerId}/${normalized}`
        : `/events/${normalized}`;
      publicLink.classList.remove("pointer-events-none", "opacity-50");
    };

    const getAvailableSections = () =>
      tabSections.filter((section) => !(isCreateMode && section.hasAttribute("data-existing-only")));

    const activateTab = (tabId) => {
      const availableSections = getAvailableSections();
      if (!availableSections.length) return;
      const nextTabId = availableSections.some((section) => section.getAttribute("data-tab-id") === tabId)
        ? tabId
        : availableSections[0].getAttribute("data-tab-id");

      tabSections.forEach((section) => {
        const isAvailable = availableSections.includes(section);
        const matches = section.getAttribute("data-tab-id") === nextTabId;
        section.classList.toggle("hidden", !isAvailable || !matches);
      });

      tabButtons.forEach((button) => {
        const thisTabId = button.getAttribute("data-tab-id");
        const isVisibleTab = availableSections.some(
          (section) => section.getAttribute("data-tab-id") === thisTabId
        );
        button.classList.toggle("hidden", !isVisibleTab);
        const isActive = isVisibleTab && thisTabId === nextTabId;
        button.classList.toggle("!bg-lime", isActive);
        button.classList.toggle("!text-ink", isActive);
        button.classList.toggle("!border-lime", isActive);
        button.setAttribute("aria-selected", isActive ? "true" : "false");
      });

      tabDots.forEach((dot) => {
        const id = dot.getAttribute("data-tab-dot-id");
        const isActive = id === nextTabId;
        const passed = dot.getAttribute("data-tab-passed") === "true";
        dot.classList.toggle("bg-white", isActive);
        dot.classList.toggle("bg-coral", !isActive && !passed);
        dot.classList.toggle("bg-lime", !isActive && passed);
      });
    };

    const sectionChecks = {
      core: () => {
        const title = String(form?.title?.value || "").trim();
        const slug = String(form?.slug?.value || "").trim();
        return Boolean(title && slug);
      },
      logistics: () => {
        const start = String(form?.startDate?.value || "").trim();
        const end = String(form?.endDate?.value || "").trim();
        return Boolean(start && end);
      },
      tracks: () => true,
      faq: () => true,
      applications: () => true,
      judging: () => true,
      exports: () => true
    };

    const refreshSectionHealth = () => {
      const availableSectionIds = getAvailableSections()
        .map((section) => section.getAttribute("data-tab-id"))
        .filter(Boolean);

      let needsWorkCount = 0;
      tabDots.forEach((dot) => {
        const id = dot.getAttribute("data-tab-dot-id");
        const isAvailable = availableSectionIds.includes(id);
        dot.classList.toggle("hidden", !isAvailable);
        if (!isAvailable) return;
        const passed = sectionChecks[id]?.() ?? true;
        dot.setAttribute("data-tab-passed", passed ? "true" : "false");
        const isActive = tabButtons.some(
          (button) =>
            button.getAttribute("data-tab-id") === id &&
            button.getAttribute("aria-selected") === "true"
        );
        dot.classList.toggle("bg-white", isActive);
        dot.classList.toggle("bg-coral", !isActive && !passed);
        dot.classList.toggle("bg-lime", !isActive && passed);
        if (!passed) needsWorkCount += 1;
      });

      if (editorHealth) {
        editorHealth.textContent =
          needsWorkCount > 0
            ? `${needsWorkCount} section${needsWorkCount === 1 ? "" : "s"} still need work`
            : "All core sections look ready";
      }
      if (editorStatus) {
        editorStatus.textContent = needsWorkCount > 0 ? "Draft" : "Ready";
        editorStatus.classList.toggle("!bg-coral/10", needsWorkCount > 0);
        editorStatus.classList.toggle("!text-coral", needsWorkCount > 0);
        editorStatus.classList.toggle("!border-coral/20", needsWorkCount > 0);
        editorStatus.classList.toggle("!bg-lime/10", needsWorkCount === 0);
        editorStatus.classList.toggle("!text-lime", needsWorkCount === 0);
        editorStatus.classList.toggle("!border-lime/20", needsWorkCount === 0);
      }
    };

    tabButtons.forEach((button) => {
      button.addEventListener("click", () => {
        const tabId = button.getAttribute("data-tab-id");
        if (!tabId) return;
        activateTab(tabId);
      });
    });

    form?.addEventListener("input", refreshSectionHealth);
    form?.addEventListener("change", refreshSectionHealth);

    editBannerFile?.addEventListener("change", async () => {
      const file = editBannerFile.files?.[0];
      if (!file || !editBannerUrl) return;
      if (editBannerUploadStatus) {
        editBannerUploadStatus.textContent = "";
        editBannerUploadStatus.classList.remove("!text-coral");
      }
      const fd = new FormData();
      fd.append("file", file);
      try {
        const res = await fetch("/api/organizer/upload/banner", { method: "POST", body: fd });
        const data = await res.json().catch(() => ({}));
        if (!res.ok) throw new Error(data.error || "Upload failed");
        editBannerUrl.value = typeof data.url === "string" ? data.url : "";
      } catch (e) {
        if (editBannerUploadStatus) {
          editBannerUploadStatus.textContent = e instanceof Error ? e.message : "Upload failed";
          editBannerUploadStatus.classList.add("!text-coral");
        }
        editBannerFile.value = "";
      }
    });

    const buildRow = (type, data = {}) => {
      const wrapper = document.createElement("div");
      wrapper.className = "card !p-8 grid md:grid-cols-[1fr_auto] items-start gap-10 animate-in fade-in slide-in-from-bottom-2 duration-300";

      if (type === "track") {
        wrapper.innerHTML = `
          <div class="grid md:grid-cols-2 gap-8 flex-1">
             <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Track name</label>
                    <input class="input-field" name="trackName" value="${data.name || ""}" placeholder="AI / Sustainability" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Prize</label>
                    <input class="input-field" name="trackPrize" value="${data.prize || ""}" placeholder="$5,000 + Macbook Pro" />
                </div>
             </div>
             <div class="space-y-2">
                <label class="form-label">Description</label>
                <textarea class="input-field !h-[calc(100%-2rem)]" name="trackDescription" rows="3" placeholder="Define the goals of this specific track...">${data.description || ""}</textarea>
             </div>
          </div>
          <button class="w-10 h-10 rounded-full bg-cream/5 flex items-center justify-center hover:bg-coral/20 hover:text-coral transition-all" type="button" data-remove>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        `;
      }

      if (type === "faq") {
        wrapper.innerHTML = `
          <div class="grid md:grid-cols-2 gap-8 flex-1">
             <div class="space-y-2">
                <label class="form-label">Question</label>
                <input class="input-field" name="faqQuestion" value="${data.question || ""}" placeholder="Is there travel reimbursement?" />
             </div>
             <div class="space-y-2">
                <label class="form-label">Answer</label>
                <textarea class="input-field" name="faqAnswer" rows="2" placeholder="Provide clarity on the subject...">${data.answer || ""}</textarea>
             </div>
          </div>
          <button class="w-10 h-10 rounded-full bg-cream/5 flex items-center justify-center hover:bg-coral/20 hover:text-coral transition-all" type="button" data-remove>
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
          </button>
        `;
      }

      if (type === "applicationField") {
        const fieldId = String(data.id || "").trim() || `${slugify(data.label || "question") || "question"}-${Date.now()}`;
        const fieldType = String(data.type || "text").trim() || "text";
        wrapper.innerHTML = `
          <div class="space-y-6 flex-1">
            <input type="hidden" name="applicationFieldId" value="${escapeHtml(fieldId)}" />
            <div class="grid gap-6 lg:grid-cols-[minmax(0,1.3fr)_180px_140px_auto]">
              <div class="space-y-2">
                <label class="form-label">Question label</label>
                <input class="input-field" name="applicationFieldLabel" value="${escapeHtml(data.label || "")}" placeholder="Why do you want to join?" />
              </div>
              <div class="space-y-2">
                <label class="form-label">Field type</label>
                <select class="input-field" name="applicationFieldType">
                  <option value="text" ${fieldType === "text" ? "selected" : ""}>Short text</option>
                  <option value="textarea" ${fieldType === "textarea" ? "selected" : ""}>Long text</option>
                  <option value="select" ${fieldType === "select" ? "selected" : ""}>Dropdown</option>
                </select>
              </div>
              <label class="flex items-center gap-3 pt-8 text-sm text-cream/70">
                <input class="h-4 w-4 rounded" type="checkbox" name="applicationFieldRequired" ${data.required ? "checked" : ""} />
                Required
              </label>
              <button class="w-10 h-10 rounded-full bg-cream/5 flex items-center justify-center hover:bg-coral/20 hover:text-coral transition-all mt-8" type="button" data-remove>
                <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="18" y1="6" x2="6" y2="18"></line><line x1="6" y1="6" x2="18" y2="18"></line></svg>
              </button>
            </div>
            <div class="grid gap-6 lg:grid-cols-2">
              <div class="space-y-2">
                <label class="form-label">Helper text</label>
                <input class="input-field" name="applicationFieldHelp" value="${escapeHtml(data.helperText || "")}" placeholder="Optional guidance for applicants" />
              </div>
              <div class="space-y-2" data-application-field-options-wrap>
                <label class="form-label">Dropdown options</label>
                <textarea class="input-field min-h-[7rem]" name="applicationFieldOptions" placeholder="Option one&#10;Option two&#10;Option three">${escapeHtml(Array.isArray(data.options) ? data.options.join("\n") : "")}</textarea>
              </div>
            </div>
          </div>
        `;

        const typeSelect = wrapper.querySelector("select[name='applicationFieldType']");
        const optionsWrap = wrapper.querySelector("[data-application-field-options-wrap]");
        const syncApplicationFieldType = () => {
          const isSelect = typeSelect?.value === "select";
          optionsWrap?.classList.toggle("hidden", !isSelect);
        };
        typeSelect?.addEventListener("change", syncApplicationFieldType);
        syncApplicationFieldType();
      }

      wrapper.querySelector("[data-remove]")?.addEventListener("click", () => {
        wrapper.style.opacity = "0";
        wrapper.style.transform = "scale(0.95)";
        setTimeout(() => wrapper.remove(), 300);
      });
      return wrapper;
    };

    addTrack?.addEventListener("click", () => {
      tracksContainer?.appendChild(buildRow("track"));
    });

    addFaq?.addEventListener("click", () => {
      faqsContainer?.appendChild(buildRow("faq"));
    });

    addApplicationField?.addEventListener("click", () => {
      applicationFieldsContainer?.appendChild(buildRow("applicationField"));
    });

    const renderApplicationsTable = (applications = []) => {
      if (!applicationsBody) return;
      if (!Array.isArray(applications) || applications.length === 0) {
        applicationsBody.innerHTML = `
          <tr>
            <td class="py-6 text-cream/40" colspan="7">No applications yet.</td>
          </tr>
        `;
        if (applicationsSummary) applicationsSummary.textContent = "No participant applications yet.";
        return;
      }

      const pendingCount = applications.filter((application) => application.status === "pending").length;
      if (applicationsSummary) {
        applicationsSummary.textContent =
          `${applications.length} total application${applications.length === 1 ? "" : "s"} • ${pendingCount} pending review`;
      }

      applicationsBody.innerHTML = applications
        .map((application) => {
          const customAnswers = application.customAnswers && typeof application.customAnswers === "object"
            ? Object.entries(application.customAnswers)
            : [];
          const detailsMarkup = [
            application.teamStatus
              ? `<div><span class="text-cream/35">Team</span><div class="mt-1 text-cream/75">${escapeHtml(application.teamStatus)}</div></div>`
              : "",
            ...customAnswers.map(
              ([label, value]) =>
                `<div><span class="text-cream/35">${escapeHtml(label)}</span><div class="mt-1 text-cream/75 whitespace-pre-wrap">${escapeHtml(value)}</div></div>`
            )
          ]
            .filter(Boolean)
            .join("");

          const statusTone =
            application.status === "approved"
              ? "!bg-lime/10 !text-lime !border-lime/20"
              : application.status === "rejected"
                ? "!bg-coral/10 !text-coral !border-coral/20"
                : "!bg-sky/10 !text-sky !border-sky/20";

          const reviewActions =
            application.status === "approved"
              ? `
                <div class="flex flex-wrap gap-2">
                  <button class="btn-ghost !px-3 !py-2 !text-[11px] uppercase tracking-[0.18em]" type="button" data-application-status data-application-id="${escapeHtml(application.id)}" data-status="rejected">Reject</button>
                </div>
              `
              : application.status === "rejected"
                ? `
                  <div class="flex flex-wrap gap-2">
                    <button class="btn-primary !px-3 !py-2 !text-[11px] uppercase tracking-[0.18em]" type="button" data-application-status data-application-id="${escapeHtml(application.id)}" data-status="approved">Approve</button>
                  </div>
                `
                : `
                  <div class="flex flex-wrap gap-2">
                    <button class="btn-primary !px-3 !py-2 !text-[11px] uppercase tracking-[0.18em]" type="button" data-application-status data-application-id="${escapeHtml(application.id)}" data-status="approved">Approve</button>
                    <button class="btn-ghost !px-3 !py-2 !text-[11px] uppercase tracking-[0.18em]" type="button" data-application-status data-application-id="${escapeHtml(application.id)}" data-status="rejected">Reject</button>
                  </div>
                `;

          return `
            <tr class="border-b border-cream/8 align-top">
              <td class="py-5 pr-4">
                <div class="font-semibold text-cream">${escapeHtml(application.fullName || "Unnamed applicant")}</div>
                <div class="mt-1 text-xs text-cream/45">${escapeHtml(application.email || "")}</div>
                <div class="mt-2 text-[11px] uppercase tracking-[0.18em] text-cream/35">${escapeHtml(application.createdAt || "")}</div>
              </td>
              <td class="py-5 pr-4 text-cream/70">${escapeHtml(application.location || "Not set")}</td>
              <td class="py-5 pr-4">
                ${application.linkedinUrl ? `<a class="text-sky hover:underline" href="${escapeHtml(application.linkedinUrl)}" target="_blank" rel="noreferrer">Open</a>` : '<span class="text-cream/35">-</span>'}
              </td>
              <td class="py-5 pr-4">
                ${application.githubUrl ? `<a class="text-sky hover:underline" href="${escapeHtml(application.githubUrl)}" target="_blank" rel="noreferrer">Open</a>` : '<span class="text-cream/35">-</span>'}
              </td>
              <td class="py-5 pr-4">
                <div class="space-y-3 text-xs leading-relaxed">
                  ${detailsMarkup || '<span class="text-cream/35">No extra answers</span>'}
                </div>
              </td>
              <td class="py-5 pr-4">
                <span class="status-pill ${statusTone}">${escapeHtml(application.status || "pending")}</span>
              </td>
              <td class="py-5">
                ${reviewActions}
              </td>
            </tr>
          `;
        })
        .join("");

      applicationsBody.querySelectorAll("[data-application-status]").forEach((button) => {
        button.addEventListener("click", async () => {
          const applicationId = button.getAttribute("data-application-id");
          const nextStatus = button.getAttribute("data-status");
          if (!applicationId || !nextStatus) return;
          button.disabled = true;
          try {
            const response = await fetch(`/api/organizer/events/${eventId}/applications/${applicationId}`, {
              method: "PATCH",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ status: nextStatus })
            });
            const result = await response.json().catch(() => ({}));
            if (!response.ok) throw new Error(result.error || "Unable to update application.");
            setStatus(`Application ${nextStatus}.`, false);
            await loadApplications();
          } catch (error) {
            setStatus(error instanceof Error ? error.message : "Unable to update application.", true);
          } finally {
            button.disabled = false;
          }
        });
      });
    };

    const loadApplications = async () => {
      if (isCreateMode || !eventId) {
        renderApplicationsTable([]);
        return;
      }

      try {
        const response = await fetch(`/api/organizer/events/${eventId}/applications`);
        if (response.status === 401) {
          window.location.href = "/organizer/login";
          return;
        }
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || "Unable to load applications.");
        }
        renderApplicationsTable(Array.isArray(payload.applications) ? payload.applications : []);
      } catch (error) {
        if (applicationsBody) {
          applicationsBody.innerHTML = `
            <tr>
              <td class="py-6 text-coral" colspan="7">${escapeHtml(error instanceof Error ? error.message : "Unable to load applications.")}</td>
            </tr>
          `;
        }
      }
    };

    const collectPayload = () => {
      const participantLocationsField = form?.querySelector("textarea[name='participantLocations']");
      const trackRows = Array.from(tracksContainer?.children || []).map((row) => ({
        name: row.querySelector("input[name='trackName']")?.value || "",
        description: row.querySelector("textarea[name='trackDescription']")?.value || "",
        prize: row.querySelector("input[name='trackPrize']")?.value || ""
      }));
      const faqRows = Array.from(faqsContainer?.children || []).map((row) => ({
        question: row.querySelector("input[name='faqQuestion']")?.value || "",
        answer: row.querySelector("textarea[name='faqAnswer']")?.value || ""
      }));
      const applicationFormFields = Array.from(applicationFieldsContainer?.children || [])
        .map((row, index) => {
          const label = row.querySelector("input[name='applicationFieldLabel']")?.value || "";
          const type = row.querySelector("select[name='applicationFieldType']")?.value || "text";
          const helperText = row.querySelector("input[name='applicationFieldHelp']")?.value || "";
          const required = Boolean(row.querySelector("input[name='applicationFieldRequired']")?.checked);
          const id =
            row.querySelector("input[name='applicationFieldId']")?.value ||
            `${slugify(label) || "question"}-${index + 1}`;
          const options = String(row.querySelector("textarea[name='applicationFieldOptions']")?.value || "")
            .split(/\r?\n/)
            .map((value) => value.trim())
            .filter(Boolean);
          return {
            id,
            label,
            type,
            helperText,
            required,
            options
          };
        })
        .filter((field) => String(field.label || "").trim());

      const maxParticipantsRaw = form.maxParticipants?.value?.trim() || "";
      const parsedMaxParticipants = Number.parseInt(maxParticipantsRaw, 10);

      return {
        title: form.title.value,
        slug: form.slug.value,
        tagline: form.tagline.value,
        description: form.description.value,
        startDate: form.startDate.value,
        endDate: form.endDate.value,
        location: form.location.value,
        participantLocations: String(participantLocationsField?.value || "")
          .split(/\r?\n/)
          .map((value) => value.trim())
          .filter(Boolean),
        applicationFormFields,
        mode: form.mode.value,
        organizationName: form.organizationName.value,
        websiteUrl: form.websiteUrl.value,
        twitterUrl: form.twitterUrl.value,
        discordUrl: form.discordUrl.value,
        maxParticipants: Number.isFinite(parsedMaxParticipants) ? parsedMaxParticipants : null,
        applicationDeadline: form.applicationDeadline.value,
        theme: "",
        bannerUrl: form.bannerUrl ? form.bannerUrl.value : "",
        isPublished: form.querySelector('input[name="isPublished"]').checked,
        tracks: trackRows.filter((track) => track.name.trim()),
        faqs: faqRows.filter((faq) => faq.question.trim() && faq.answer.trim())
      };
    };

    const loadEvent = async () => {
      try {
        const response = await fetch(`/api/organizer/events/${eventId}`);
        if (response.status === 401) {
          window.location.href = "/organizer/login";
          return;
        }
        const payload = await response.json();
        const event = payload.event;
        if (!event) throw new Error("Event dataset not found.");
        currentOrganizerId = String(event.organizerId || "");

        if (titleEl) titleEl.textContent = event.title;
        if (form) {
          form.title.value = event.title || "";
          form.slug.value = event.slug || "";
          form.tagline.value = event.tagline || "";
          form.description.value = event.description || "";
          form.startDate.value = formatForInput(event.startDate);
          form.endDate.value = formatForInput(event.endDate);
          form.location.value = event.location || "";
          const participantLocationsField = form.querySelector("textarea[name='participantLocations']");
          if (participantLocationsField) {
            participantLocationsField.value = Array.isArray(event.participantLocations)
              ? event.participantLocations.join("\n")
              : "";
          }
          form.mode.value = event.mode || "Hybrid";
          form.organizationName.value = event.organizationName || "";
          form.websiteUrl.value = event.websiteUrl || "";
          form.twitterUrl.value = event.twitterUrl || "";
          form.discordUrl.value = event.discordUrl || "";
          form.maxParticipants.value = event.maxParticipants || "";
          form.applicationDeadline.value = formatForInput(event.applicationDeadline);
          form.isPublished.checked = !!event.isPublished;
          if (form.bannerUrl) form.bannerUrl.value = event.bannerUrl || "";
        }

        setPublicLink(event.slug);
        if (applicationsLink) applicationsLink.href = `/api/organizer/events/${eventId}/applications.csv`;
        if (submissionsLink) submissionsLink.href = `/api/organizer/events/${eventId}/submissions.csv`;

        tracksContainer.innerHTML = "";
        (payload.tracks || []).forEach((track) => {
          tracksContainer.appendChild(buildRow("track", track));
        });

        faqsContainer.innerHTML = "";
        (payload.faqs || []).forEach((faq) => {
          faqsContainer.appendChild(buildRow("faq", faq));
        });
        applicationFieldsContainer.innerHTML = "";
        (event.applicationFormFields || []).forEach((field) => {
          applicationFieldsContainer.appendChild(buildRow("applicationField", field));
        });
        await loadApplications();
        refreshSectionHealth();
      } catch (error) {
        setStatus("Unable to load event: " + (error instanceof Error ? error.message : "Unknown error."), true);
      }
    };

    let slugTouched = false;

    titleInput?.addEventListener("input", () => {
      if (!isCreateMode || !slugInput) return;
      if (!slugTouched) {
        slugInput.value = slugify(titleInput.value);
      }
      setPublicLink(slugInput.value);
    });

    slugInput?.addEventListener("input", () => {
      if (!isCreateMode) return;
      slugTouched = true;
      setPublicLink(slugInput.value);
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form) return;

      setButtonsState(true, isCreateMode ? "Creating..." : "Saving...", isCreateMode ? "Creating..." : "Saving...");
      clearStatus();

      const payload = collectPayload();

      try {
        if (isCreateMode) {
          const createResponse = await fetch("/api/organizer/events", {
            method: "POST",
            headers: { "content-type": "application/json" },
            body: JSON.stringify(payload)
          });
          if (createResponse.status === 401) {
            window.location.href = "/organizer/login";
            return;
          }

          const createResult = await createResponse.json().catch(() => ({}));
          if (!createResponse.ok) {
            throw new Error(createResult.error || "Unable to create event.");
          }

          const createdId = createResult?.event?.id;
          currentOrganizerId = String(createResult?.event?.organizerId || currentOrganizerId);
          if (!createdId) {
            throw new Error("Event created but no event id was returned.");
          }

          if (payload.tracks.length > 0 || payload.faqs.length > 0) {
            const enrichResponse = await fetch(`/api/organizer/events/${createdId}`, {
              method: "PUT",
              headers: { "content-type": "application/json" },
              body: JSON.stringify(payload)
            });
            if (!enrichResponse.ok) {
              const enrichResult = await enrichResponse.json().catch(() => ({}));
              setStatus(
                `Event created, but tracks/FAQ were not saved yet (${enrichResult.error || "follow-up save failed"}). Opening editor...`,
                true
              );
              setTimeout(() => {
                window.location.href = `/organizer/events/${createdId}`;
              }, 1200);
              return;
            }
          }

          window.location.href = `/organizer/events/${createdId}`;
          return;
        }

        const response = await fetch(`/api/organizer/events/${eventId}`, {
          method: "PUT",
          headers: { "content-type": "application/json" },
          body: JSON.stringify(payload)
        });
        if (response.status === 401) {
          window.location.href = "/organizer/login";
          return;
        }

        const result = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(result.error || "Unable to save event.");
        }
        setButtonsState(false, defaultTopLabel, defaultSubmitLabel);
        setStatus("Changes saved.", false);
        setTimeout(() => clearStatus(), 2000);
        return;
      } catch (error) {
        submitBtn?.classList.remove("btn-primary--success");
        setButtonsState(false, defaultTopLabel, isCreateMode ? "Create event" : "Retry save");
        setStatus(error instanceof Error ? error.message : "Unable to save event.", true);
      }
    });

    if (isCreateMode) {
      if (titleEl) titleEl.textContent = "Create event";
      if (subtitleEl) subtitleEl.textContent = "Set up a brand-new event, then fine-tune details before you publish.";
      existingOnlyEls.forEach((el) => el.classList.add("hidden"));
      setButtonsState(false, defaultTopLabel, defaultSubmitLabel);
      if (form?.mode) form.mode.value = "Hybrid";
      setPublicLink(form?.slug?.value || "");
      activateTab("core");
      renderApplicationsTable([]);
      refreshSectionHealth();
    } else {
      setButtonsState(false, defaultTopLabel, defaultSubmitLabel);
      activateTab("core");
      loadEvent();
    }
  </script>

  <script>
    import { initJudgingWorkspace } from "../../../../lib/client/judging-workspace";

    const judgingRoot = document.querySelector("[data-judging-root]");
    const judgingEventId = judgingRoot?.getAttribute("data-judging-event-id")?.trim() || "";
    if (judgingRoot && judgingEventId) {
      initJudgingWorkspace(judgingRoot, judgingEventId);
    }
  </script>
</BaseLayout>
