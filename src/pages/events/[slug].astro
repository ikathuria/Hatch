---
import BaseLayout from "../../layouts/BaseLayout.astro";
import HatchEggMark from "../../components/HatchEggMark.astro";
---

<BaseLayout title="Event Details | Hatch">
  {/* Event Hero */}
  <section class="relative overflow-hidden pb-16 pt-12">
    <div class="site-glow opacity-30"></div>
    <div class="relative z-10 mx-auto max-w-6xl px-6">
      <div class="grid gap-8 lg:grid-cols-[minmax(320px,380px)_minmax(0,1fr)]">
        <div class="space-y-5">
          <div class="card event-poster-card !p-0 overflow-hidden border-cream/[0.08]">
            <div class="relative aspect-square overflow-hidden bg-[radial-gradient(circle_at_top,_rgba(232,171,72,0.2),_transparent_34%),linear-gradient(180deg,_rgba(31,23,18,0.98),_rgba(17,13,10,0.96))]">
              <div class="absolute inset-0 flex flex-col items-center justify-center gap-5 px-8 text-center" data-event-banner-placeholder>
                <div class="event-poster-ring event-poster-ring--outer" aria-hidden="true"></div>
                <div class="event-poster-ring event-poster-ring--inner" aria-hidden="true"></div>
                <div class="event-poster-crack" aria-hidden="true"></div>
                <div class="flex h-18 w-18 items-center justify-center rounded-full border border-cream/[0.12] bg-cream/[0.03] text-lime">
                  <HatchEggMark class="h-10 w-7" />
                </div>
                <div class="space-y-2">
                  <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-lime/75">Hatch event page</p>
                  <p class="text-sm leading-relaxed text-cream/55">A published banner will appear here. Until then, the event stays crisp and launch-ready.</p>
                </div>
              </div>

              <div class="absolute inset-0 hidden" data-event-banner-wrap>
                <img class="h-full w-full object-cover" data-event-banner alt="" />
                <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink via-ink/[0.15] to-transparent" aria-hidden="true"></div>
              </div>
            </div>
          </div>

          <div class="grid gap-4" data-event-facts>
            <div class="card !p-6 text-cream/35 italic border-dashed">Loading event facts...</div>
          </div>

          <div class="card !p-7 hidden" data-event-socials-card>
            <h3 class="mb-5 font-mono text-[0.72rem] uppercase tracking-[0.24em] text-lime">Connect</h3>
            <div class="space-y-4" data-event-socials>
              <!-- Hydrated by JS -->
            </div>
          </div>
        </div>

        <div class="space-y-6">
          <div class="card !p-8 md:!p-10">
            <div class="space-y-7">
              <div class="flex flex-wrap items-center gap-4">
                <span class="eyebrow !border-sky/[0.2] !bg-sky/[0.08] !text-sky" data-event-mode>Loading...</span>
                <span class="font-mono text-[0.7rem] uppercase tracking-[0.22em] text-cream/[0.42] hidden" data-event-org></span>
              </div>

              <div class="space-y-4">
                <h1 class="max-w-4xl text-4xl font-bold leading-tight tracking-[-0.07em] md:text-6xl" data-event-title>
                  Synchronizing...
                </h1>
                <p class="max-w-3xl text-lg font-medium leading-relaxed text-cream/[0.62]" data-event-tagline></p>
              </div>

              <div class="card !p-6 event-callout-card">
                <div class="flex flex-col gap-5 md:flex-row md:items-start md:justify-between">
                  <div class="space-y-3">
                    <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-lime">Take your place</p>
                    <p class="max-w-xl text-sm leading-relaxed text-cream/[0.58]">
                      Apply, submit, and share this event from one clean public page.
                    </p>
                  </div>
                  <div class="flex flex-wrap gap-3">
                    <a class="btn-primary !px-8 !py-3.5" data-apply-link href="#">Apply to Participate</a>
                    <a class="btn-ghost !px-8 !py-3.5" data-submit-link href="#">Submit project</a>
                  </div>
                </div>

                <div class="mt-5 flex flex-wrap items-center gap-3 border-t border-cream/[0.08] pt-5">
                  <button class="btn-ghost !px-5 !py-2 !text-xs" type="button" data-copy-link>
                    Copy event link
                  </button>
                  <a class="btn-ghost !px-5 !py-2 !text-xs" href="#" data-google-calendar target="_blank" rel="noreferrer">
                    Add to Google Calendar
                  </a>
                  <a class="btn-ghost !px-5 !py-2 !text-xs" href="#" data-ics-download>
                    Download .ics
                  </a>
                </div>
                <span class="mt-4 block text-xs text-cream/[0.45] hidden" data-share-status role="status" aria-live="polite"></span>
              </div>

              <div class="grid gap-5 xl:grid-cols-[minmax(0,1fr)_290px]">
                <div class="card !p-7">
                  <h2 class="mb-5 font-mono text-[0.72rem] uppercase tracking-[0.24em] text-coral">About the Event</h2>
                  <p class="max-w-3xl whitespace-pre-wrap text-base leading-relaxed text-cream/[0.72] md:text-lg" data-event-description></p>
                </div>

                <div class="card !p-7 border-violet/18 bg-violet/[0.04]">
                  <h3 class="mb-5 font-mono text-[0.72rem] uppercase tracking-[0.24em] text-violet">Event Status</h3>
                  <div class="space-y-5">
                    <div class="flex items-center gap-4">
                      <div class="h-2 w-2 rounded-full bg-lime animate-pulse"></div>
                      <span class="text-sm font-medium text-cream" data-event-status-label>Loading status...</span>
                    </div>
                    <p class="text-sm leading-relaxed text-cream/[0.52]" data-event-status-copy>Loading event status...</p>
                    <p class="font-mono text-[0.68rem] uppercase tracking-[0.22em] text-cream/[0.4] hidden" data-event-countdown></p>
                    <a href="mailto:hello@hatch.dev" class="btn-ghost !w-full !justify-center !py-3 !text-xs uppercase tracking-widest" data-contact-link>
                      Contact Organizer
                    </a>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  {/* Public Content Grid */}
  <section class="pb-32 relative" data-public-content>
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid gap-16 lg:grid-cols-[1fr_330px]">
        {/* Main Content: Tabs */}
        <div class="space-y-10">
            <nav class="card !p-3 flex flex-wrap gap-2 w-fit" data-content-tabs>
              <button class="btn-ghost !px-5 !py-2 !text-xs" type="button" data-tab-btn data-tab-target="tracks">Tracks</button>
              <button class="btn-ghost !px-5 !py-2 !text-xs" type="button" data-tab-btn data-tab-target="gallery">Project Gallery</button>
              <button class="btn-ghost !px-5 !py-2 !text-xs" type="button" data-tab-btn data-tab-target="faq">FAQ</button>
            </nav>

            <section data-tab-panel="tracks">
              <h2 class="section-title text-4xl">Event Tracks</h2>
              <div class="grid gap-6 mt-10" data-event-tracks>
                <div class="card !p-12 text-cream/20 italic border-dashed">Awaiting track definitions...</div>
              </div>
            </section>

            <section data-tab-panel="gallery" class="hidden">
              <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
                <div>
                  <h2 class="section-title text-4xl !mb-0">Project Gallery</h2>
                  <p class="text-cream/45 mt-3">Winners and community favorites appear after results are published.</p>
                </div>
                <div class="card !p-5 w-full md:w-auto space-y-3" data-participant-auth>
                  <p class="text-xs font-bold uppercase tracking-widest text-cream/35">Participant Voting</p>
                  <p class="text-xs text-cream/55 leading-relaxed" data-participant-auth-copy>
                    Apply and sign in as a participant to vote.
                  </p>
                  <div class="flex items-center gap-3">
                    <a class="btn-primary !px-5 !py-3 !text-sm" data-participant-apply-link href="#">Apply to participate</a>
                    <button class="btn-ghost !px-4 !py-2 !text-xs hidden" data-participant-logout type="button">Sign out</button>
                  </div>
                  <span class="text-xs text-cream/40 hidden" data-participant-email></span>
                  <span class="status-pill hidden !bg-transparent !border-none !p-0 !text-xs" data-participant-status role="status" aria-live="polite"></span>
                </div>
              </div>
              <div class="grid gap-6 mt-10" data-event-gallery>
                <div class="card !p-12 text-cream/20 italic border-dashed">Project gallery is awaiting published results.</div>
              </div>
            </section>

            <section data-tab-panel="faq" class="hidden">
              <h2 class="section-title text-4xl">Frequently Asked</h2>
              <div class="grid gap-4 mt-10" data-event-faqs>
                <div class="card !p-12 text-cream/20 italic border-dashed">Loading FAQs...</div>
              </div>
            </section>
        </div>

        {/* Sidebar: Dynamic Info */}
        <aside class="space-y-8">
            <div class="card !p-8">
                <h3 class="mb-6 font-mono text-[0.72rem] uppercase tracking-[0.24em] text-sky">Need Support?</h3>
                <p class="mb-6 text-sm leading-relaxed text-cream/[0.5]">Reach out to the organizers if you have questions about logistics, tracks, or deadlines.</p>
                <a href="mailto:hello@hatch.dev" class="btn-ghost !w-full !justify-center !py-3 !text-xs uppercase tracking-widest" data-contact-link>Contact Organizer</a>
            </div>
        </aside>
      </div>
    </div>
  </section>

  <section id="hacker-space" class="relative hidden pb-32" data-workspace>
    <div class="mx-auto max-w-6xl px-6">
      <div class="card !p-6 md:!p-8">
        <div class="flex flex-col gap-6 border-b border-cream/[0.08] pb-6 md:flex-row md:items-center md:justify-between">
          <div class="space-y-2">
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-lime">Attendee workspace</p>
            <h2 class="text-3xl font-bold tracking-[-0.06em] md:text-4xl">Hacker space</h2>
            <p class="text-sm leading-relaxed text-cream/[0.56]" data-workspace-summary>
              Loading attendee workspace...
            </p>
          </div>
          <div class="flex flex-wrap items-center gap-3">
            <span class="status-pill !border-lime/20 !bg-lime/[0.08] !text-lime hidden" data-workspace-email></span>
            <button class="btn-ghost !px-4 !py-2 !text-xs hidden" data-workspace-logout type="button">Sign out</button>
          </div>
        </div>

        <div class="mt-8 grid gap-8 lg:grid-cols-[220px_minmax(0,1fr)]">
          <aside class="space-y-3">
            <button class="workspace-nav-btn is-active" type="button" data-workspace-tab-btn data-workspace-tab-target="information">
              Information
            </button>
            <button class="workspace-nav-btn" type="button" data-workspace-tab-btn data-workspace-tab-target="resources">
              Resources
            </button>
            <button class="workspace-nav-btn" type="button" data-workspace-tab-btn data-workspace-tab-target="teams">
              Teams
            </button>
            <button class="workspace-nav-btn" type="button" data-workspace-tab-btn data-workspace-tab-target="submissions">
              Submissions
            </button>
          </aside>

          <div class="space-y-5">
            <section data-workspace-panel="information">
              <div class="workspace-panel" data-workspace-information></div>
            </section>

            <section class="hidden" data-workspace-panel="resources">
              <div class="workspace-panel" data-workspace-resources></div>
            </section>

            <section class="hidden" data-workspace-panel="teams">
              <div class="workspace-panel" data-workspace-teams></div>
            </section>

            <section class="hidden" data-workspace-panel="submissions">
              <div class="workspace-panel" data-workspace-submission></div>
            </section>
          </div>
        </div>
      </div>
    </div>
  </section>

  <style>
      .event-poster-card {
          box-shadow: 0 28px 70px rgba(0, 0, 0, 0.35);
      }

      .event-poster-ring {
          position: absolute;
          border: 1px solid rgba(255, 248, 236, 0.08);
          border-radius: 999px;
      }

      .event-poster-ring--outer {
          inset: 2.4rem;
      }

      .event-poster-ring--inner {
          inset: 5.6rem;
          border-color: rgba(131, 186, 196, 0.2);
      }

      .event-poster-crack {
          position: absolute;
          top: 5rem;
          left: 50%;
          width: 5px;
          height: 11rem;
          margin-left: -2px;
          border-radius: 999px;
          background: linear-gradient(180deg, rgba(120, 166, 175, 0.95), rgba(232, 171, 72, 0.95));
          clip-path: polygon(45% 0%, 0% 14%, 70% 32%, 24% 48%, 84% 67%, 34% 84%, 58% 100%, 100% 100%, 100% 0%);
          filter: drop-shadow(0 0 14px rgba(232, 171, 72, 0.28));
      }

      .event-callout-card {
          background:
              radial-gradient(circle at top left, rgba(232, 171, 72, 0.08), transparent 34%),
              linear-gradient(180deg, rgba(31, 23, 18, 0.98), rgba(22, 17, 14, 0.95));
      }

      .workspace-nav-btn {
          width: 100%;
          display: inline-flex;
          align-items: center;
          justify-content: flex-start;
          border: 1px solid transparent;
          border-radius: 0.85rem;
          background: transparent;
          color: rgba(234, 223, 208, 0.62);
          font-family: "IBM Plex Mono", monospace;
          font-size: 0.78rem;
          letter-spacing: 0.16em;
          padding: 0.95rem 1rem;
          text-transform: uppercase;
          transition: border-color 180ms ease, background 180ms ease, color 180ms ease;
      }

      .workspace-nav-btn:hover,
      .workspace-nav-btn.is-active {
          background: rgba(232, 171, 72, 0.08);
          border-color: rgba(232, 171, 72, 0.18);
          color: rgba(252, 246, 234, 0.96);
      }

      .workspace-panel {
          border: 1px solid rgba(234, 223, 208, 0.08);
          border-radius: 1rem;
          background: linear-gradient(180deg, rgba(28, 22, 18, 0.98), rgba(18, 14, 12, 0.96));
          padding: 1.5rem;
      }

      details[open] summary svg {
          transform: rotate(180deg);
      }

      @media (max-width: 767px) {
          .event-poster-ring--outer {
              inset: 1.6rem;
          }

          .event-poster-ring--inner {
              inset: 4rem;
          }

          .event-poster-crack {
              top: 3.6rem;
              height: 8.8rem;
          }
      }
  </style>

  <script>
    const pathParts = window.location.pathname.split("/").filter(Boolean);
    const slug = pathParts[pathParts.length - 1] || "";
    const organizerId = pathParts.length >= 3 ? pathParts[pathParts.length - 2] : "";
    const routeBase = organizerId ? `/events/${organizerId}/${slug}` : `/events/${slug}`;
    const querySuffix = organizerId ? `?organizerId=${encodeURIComponent(organizerId)}` : "";
    const titleEl = document.querySelector("[data-event-title]");
    const taglineEl = document.querySelector("[data-event-tagline]");
    const descEl = document.querySelector("[data-event-description]");
    const publicContentEl = document.querySelector("[data-public-content]");
    const workspaceEl = document.querySelector("[data-workspace]");
    const workspaceSummaryEl = document.querySelector("[data-workspace-summary]");
    const workspaceEmailEl = document.querySelector("[data-workspace-email]");
    const workspaceLogoutBtn = document.querySelector("[data-workspace-logout]");
    const workspaceTabButtons = Array.from(document.querySelectorAll("[data-workspace-tab-btn]"));
    const workspacePanels = Array.from(document.querySelectorAll("[data-workspace-panel]"));
    const workspaceInfoEl = document.querySelector("[data-workspace-information]");
    const workspaceResourcesEl = document.querySelector("[data-workspace-resources]");
    const workspaceTeamsEl = document.querySelector("[data-workspace-teams]");
    const workspaceSubmissionEl = document.querySelector("[data-workspace-submission]");
    const factsEl = document.querySelector("[data-event-facts]");
    const modeEl = document.querySelector("[data-event-mode]");
    const tracksEl = document.querySelector("[data-event-tracks]");
    const faqsEl = document.querySelector("[data-event-faqs]");
    const galleryEl = document.querySelector("[data-event-gallery]");
    const tabButtons = Array.from(document.querySelectorAll("[data-tab-btn]"));
    const tabPanels = Array.from(document.querySelectorAll("[data-tab-panel]"));
    const applyLink = document.querySelector("[data-apply-link]");
    const submitLink = document.querySelector("[data-submit-link]");
    const orgEl = document.querySelector("[data-event-org]");
    const socialsCard = document.querySelector("[data-event-socials-card]");
    const socialsEl = document.querySelector("[data-event-socials]");
    const bannerWrap = document.querySelector("[data-event-banner-wrap]");
    const bannerImg = document.querySelector("[data-event-banner]");
    const bannerPlaceholder = document.querySelector("[data-event-banner-placeholder]");
    const participantAuthCard = document.querySelector("[data-participant-auth]");
    const participantAuthCopy = document.querySelector("[data-participant-auth-copy]");
    const participantApplyLink = document.querySelector("[data-participant-apply-link]");
    const participantEmailEl = document.querySelector("[data-participant-email]");
    const participantLogoutBtn = document.querySelector("[data-participant-logout]");
    const participantStatusEl = document.querySelector("[data-participant-status]");
    const eventStatusLabel = document.querySelector("[data-event-status-label]");
    const eventStatusCopy = document.querySelector("[data-event-status-copy]");
    const eventCountdownEl = document.querySelector("[data-event-countdown]");
    const copyLinkBtn = document.querySelector("[data-copy-link]");
    const shareStatusEl = document.querySelector("[data-share-status]");
    const googleCalendarLink = document.querySelector("[data-google-calendar]");
    const icsDownloadLink = document.querySelector("[data-ics-download]");
    const contactLinks = Array.from(document.querySelectorAll("[data-contact-link]"));

    const BANNER_PREFIX = "/api/media/banner/";
    const BANNER_UUID =
      /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;

    const state = {
      event: null,
      tracks: [],
      gallery: [],
      winners: null,
      resultsPublished: false,
      participantEventId: "",
      participantSessionEmail: "",
      participantEmail: "",
      votedSubmissionIds: new Set(),
      workspace: null,
      workspaceNotice: { panel: "", message: "", tone: "" }
    };

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const setStatus = (el, message, tone = "") => {
      if (!el) return;
      if (!message) {
        el.textContent = "";
        el.classList.add("hidden");
        el.classList.remove("!text-lime", "!text-coral", "!text-sky");
        return;
      }
      el.textContent = message;
      el.classList.remove("hidden", "!text-lime", "!text-coral", "!text-sky");
      if (tone) el.classList.add(tone);
    };

    const activateTab = (tabId) => {
      tabButtons.forEach((button) => {
        const active = button.getAttribute("data-tab-target") === tabId;
        button.classList.toggle("!bg-lime/10", active);
        button.classList.toggle("!border-lime/20", active);
        button.classList.toggle("!text-lime", active);
      });
      tabPanels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.getAttribute("data-tab-panel") !== tabId);
      });
    };

    tabButtons.forEach((button) => {
      button.addEventListener("click", () =>
        activateTab(button.getAttribute("data-tab-target") || "tracks")
      );
    });

    const activateWorkspaceTab = (tabId) => {
      workspaceTabButtons.forEach((button) => {
        const active = button.getAttribute("data-workspace-tab-target") === tabId;
        button.classList.toggle("is-active", active);
      });
      workspacePanels.forEach((panel) => {
        panel.classList.toggle("hidden", panel.getAttribute("data-workspace-panel") !== tabId);
      });
    };

    workspaceTabButtons.forEach((button) => {
      button.addEventListener("click", () =>
        activateWorkspaceTab(button.getAttribute("data-workspace-tab-target") || "information")
      );
    });

    const isBannerImageSrc = (value) => {
      const s = String(value).trim();
      if (!s) return false;
      if (s.startsWith(BANNER_PREFIX)) {
        return BANNER_UUID.test(s.slice(BANNER_PREFIX.length));
      }
      try {
        const u = new URL(s);
        return u.protocol === "http:" || u.protocol === "https:";
      } catch {
        return false;
      }
    };

    const formatDate = (value) => {
      if (!value) return "TBD";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return new Intl.DateTimeFormat(undefined, {
        month: "short",
        day: "numeric",
        year: "numeric"
      }).format(date);
    };

    const formatDateTimeForCalendar = (value) => {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return "";
      const pad = (input) => String(input).padStart(2, "0");
      return `${date.getUTCFullYear()}${pad(date.getUTCMonth() + 1)}${pad(date.getUTCDate())}T${pad(
        date.getUTCHours()
      )}${pad(date.getUTCMinutes())}${pad(date.getUTCSeconds())}Z`;
    };

    const asDateValue = (value) => {
      const date = new Date(value);
      const time = date.getTime();
      return Number.isNaN(time) ? null : time;
    };

    const formatDuration = (ms) => {
      const totalHours = Math.max(0, Math.floor(ms / (1000 * 60 * 60)));
      const days = Math.floor(totalHours / 24);
      const hours = totalHours % 24;
      if (days > 0) return `${days}d ${hours}h`;
      return `${hours}h`;
    };

    const renderWorkspaceNotice = (panel) => {
      if (state.workspaceNotice.panel !== panel || !state.workspaceNotice.message) return "";
      const toneClass =
        state.workspaceNotice.tone === "lime"
          ? "text-lime"
          : state.workspaceNotice.tone === "coral"
            ? "text-coral"
            : "text-sky";
      return `<p class="mt-4 text-sm ${toneClass}">${escapeHtml(state.workspaceNotice.message)}</p>`;
    };

    const toggleWorkspaceMode = () => {
      const active = Boolean(state.participantEmail && state.workspace);
      workspaceEl?.classList.toggle("hidden", !active);
      publicContentEl?.classList.toggle("hidden", active);

      if (workspaceEmailEl) {
        if (active) {
          workspaceEmailEl.textContent = state.participantEmail;
          workspaceEmailEl.classList.remove("hidden");
        } else {
          workspaceEmailEl.textContent = "";
          workspaceEmailEl.classList.add("hidden");
        }
      }

      if (workspaceLogoutBtn) {
        workspaceLogoutBtn.classList.toggle("hidden", !state.participantSessionEmail);
      }
    };

    const renderWorkspaceInformation = () => {
      if (!workspaceInfoEl || !state.workspace) return;
      const participant = state.workspace.participant || {};
      const event = state.workspace.event || state.event || {};

      workspaceInfoEl.innerHTML = `
        <div class="space-y-6">
          <div>
            <p class="font-mono text-[0.68rem] uppercase tracking-[0.24em] text-coral">Information</p>
            <p class="mt-4 text-lg leading-relaxed text-cream/[0.72]">
              ${escapeHtml(event.description || event.tagline || "Attendee details will appear here as the event takes shape.")}
            </p>
          </div>
          <div class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="card !p-5">
