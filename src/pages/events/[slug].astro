---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Event Details | Hatch">
  {/* Event Hero */}
  <section class="relative pt-12 pb-24 overflow-hidden">
    <div class="site-glow opacity-30"></div>
    <div class="mx-auto max-w-6xl px-6 relative z-10">
      <div class="card !p-0 overflow-hidden border-cream/10 shadow-[0_30px_100px_rgba(0,0,0,0.5)]">
        <div class="relative hidden max-h-64 w-full overflow-hidden border-b border-cream/10 bg-cream/[0.03]" data-event-banner-wrap>
          <img class="h-full w-full max-h-64 object-cover" data-event-banner alt="" />
          <div class="pointer-events-none absolute inset-0 bg-gradient-to-t from-ink via-ink/40 to-transparent" aria-hidden="true"></div>
        </div>
        <div class="bg-gradient-to-br from-violet/20 via-sky/10 to-transparent p-12 md:p-20">
            <div class="space-y-8 max-w-4xl">
                <div class="flex flex-wrap items-center gap-4">
                  <span class="eyebrow !text-sky !bg-sky/10 !border-sky/20" data-event-mode>Loading...</span>
                  <span class="text-xs uppercase tracking-widest text-cream/40 font-bold border-l border-cream/10 pl-4 hidden" data-event-org></span>
                </div>
                <h1 class="text-5xl md:text-7xl font-bold tracking-tighter leading-tight" data-event-title>
                    Synchronizing...
                </h1>
                <p class="text-xl text-cream/60 leading-relaxed font-medium" data-event-tagline></p>
                
                <div class="flex flex-wrap gap-8 text-sm font-bold uppercase tracking-widest text-cream/40 py-6 border-y border-cream/5" data-event-meta>
                    {/* Hydrated by JS */}
                </div>

                <div class="flex flex-wrap gap-6 pt-4">
                    <a class="btn-primary !px-12 !py-4" data-apply-link href="#">Apply to Participate</a>
                    <a class="btn-ghost !px-12 !py-4" data-submit-link href="#">Submit Project</a>
                </div>
                <div class="flex flex-wrap items-center gap-3">
                  <button class="btn-ghost !px-5 !py-2 !text-xs" type="button" data-copy-link>
                    Copy event link
                  </button>
                  <a class="btn-ghost !px-5 !py-2 !text-xs" href="#" data-google-calendar target="_blank" rel="noreferrer">
                    Add to Google Calendar
                  </a>
                  <a class="btn-ghost !px-5 !py-2 !text-xs" href="#" data-ics-download>
                    Download .ics
                  </a>
                </div>
                <span class="text-xs text-cream/45 hidden" data-share-status></span>
            </div>
        </div>
        
        <div class="p-12 md:p-20 bg-ink-muted/30 backdrop-blur-xl">
            <h2 class="text-xs font-bold uppercase tracking-[0.3em] text-violet mb-6">About the Event</h2>
            <p class="text-lg text-cream/70 leading-relaxed max-w-4xl whitespace-pre-wrap" data-event-description></p>
        </div>
      </div>
    </div>
  </section>

  {/* Content Grid */}
  <section class="pb-32 relative">
    <div class="mx-auto max-w-6xl px-6">
      <div class="grid lg:grid-cols-[1fr_350px] gap-16">
        {/* Main Content: Tracks */}
        <div class="space-y-16">
            <div>
                <h2 class="section-title text-4xl">Event Tracks</h2>
                <div class="grid gap-6 mt-10" data-event-tracks>
                    <div class="card !p-12 text-cream/20 italic border-dashed">Awaiting track definitions...</div>
                </div>
            </div>

            <div>
                <div class="flex flex-col gap-6 md:flex-row md:items-end md:justify-between">
                    <div>
                        <h2 class="section-title text-4xl !mb-0">Project Gallery</h2>
                        <p class="text-cream/45 mt-3">Winners and community favorites appear after results are published.</p>
                    </div>
                    <div class="card !p-5 w-full md:w-auto space-y-3" data-participant-auth>
                        <p class="text-xs font-bold uppercase tracking-widest text-cream/35">Participant Voting</p>
                        <form class="flex flex-col sm:flex-row gap-3" data-participant-login-form>
                            <input class="input-field !py-3 !px-4 !text-sm" name="email" type="email" placeholder="you@example.com" />
                            <button class="btn-primary !px-5 !py-3 !text-sm" type="submit">Get Magic Link</button>
                        </form>
                        <div class="flex items-center justify-between gap-4">
                            <span class="text-xs text-cream/40 hidden" data-participant-email></span>
                            <button class="btn-ghost !px-4 !py-2 !text-xs hidden" data-participant-logout type="button">Sign Out</button>
                        </div>
                        <div class="text-xs text-cream/45 hidden" data-participant-link-wrap>
                            <a class="text-lime font-bold hover:underline" data-participant-link href="#" target="_self">Open your magic link</a>
                        </div>
                        <span class="status-pill hidden !bg-transparent !border-none !p-0 !text-xs" data-participant-status></span>
                    </div>
                </div>
                <div class="grid gap-6 mt-10" data-event-gallery>
                    <div class="card !p-12 text-cream/20 italic border-dashed">Project gallery is awaiting published results.</div>
                </div>
            </div>

            <div>
                <h2 class="section-title text-4xl">Frequently Asked</h2>
                <div class="grid gap-4 mt-10" data-event-faqs>
                    <div class="card !p-12 text-cream/20 italic border-dashed">FAQ grid is Offline.</div>
                </div>
            </div>
        </div>

        {/* Sidebar: Dynamic Info */}
        <aside class="space-y-8">
            <div class="card !p-8 border-violet/20 bg-violet/5">
                <h3 class="text-sm font-bold uppercase tracking-widest text-violet mb-6">Event Status</h3>
                <div class="space-y-6">
                    <div class="flex items-center gap-4">
                        <div class="w-2 h-2 rounded-full bg-lime animate-pulse"></div>
                        <span class="text-sm font-medium text-cream" data-event-status-label>Loading status...</span>
                    </div>
                    <p class="text-xs text-cream/40 leading-relaxed" data-event-status-copy>Join a community of builders and manifest your vision into reality.</p>
                    <p class="text-xs uppercase tracking-widest text-cream/45" data-event-countdown></p>
                </div>
            </div>

            <div class="card !p-8 hidden" data-event-socials-card>
                <h3 class="text-sm font-bold uppercase tracking-widest text-lime mb-6">Connect & Share</h3>
                <div class="space-y-6" data-event-socials>
                    <!-- Hydrated by JS -->
                </div>
            </div>

            <div class="card !p-8">
                <h3 class="text-sm font-bold uppercase tracking-widest text-sky mb-6">Need Support?</h3>
                <p class="text-sm text-cream/50 mb-6">Reach out to the organizers if you have questions about the logistics or tracks.</p>
                <a href="mailto:hello@hatch.dev" class="btn-ghost !w-full !py-3 !text-xs justify-center uppercase tracking-widest" data-contact-link>Contact Organizer</a>
            </div>
        </aside>
      </div>
    </div>
  </section>

  <style>
      details[open] summary svg {
          transform: rotate(180deg);
      }
  </style>

  <script>
    const pathParts = window.location.pathname.split("/").filter(Boolean);
    const slug = pathParts[pathParts.length - 1] || "";
    const organizerId = pathParts.length >= 3 ? pathParts[pathParts.length - 2] : "";
    const routeBase = organizerId ? `/events/${organizerId}/${slug}` : `/events/${slug}`;
    const querySuffix = organizerId ? `?organizerId=${encodeURIComponent(organizerId)}` : "";
    const titleEl = document.querySelector("[data-event-title]");
    const taglineEl = document.querySelector("[data-event-tagline]");
    const descEl = document.querySelector("[data-event-description]");
    const metaEl = document.querySelector("[data-event-meta]");
    const modeEl = document.querySelector("[data-event-mode]");
    const tracksEl = document.querySelector("[data-event-tracks]");
    const faqsEl = document.querySelector("[data-event-faqs]");
    const galleryEl = document.querySelector("[data-event-gallery]");
    const applyLink = document.querySelector("[data-apply-link]");
    const submitLink = document.querySelector("[data-submit-link]");
    const orgEl = document.querySelector("[data-event-org]");
    const socialsCard = document.querySelector("[data-event-socials-card]");
    const socialsEl = document.querySelector("[data-event-socials]");
    const bannerWrap = document.querySelector("[data-event-banner-wrap]");
    const bannerImg = document.querySelector("[data-event-banner]");
    const participantLoginForm = document.querySelector("[data-participant-login-form]");
    const participantAuthCard = document.querySelector("[data-participant-auth]");
    const participantEmailEl = document.querySelector("[data-participant-email]");
    const participantLogoutBtn = document.querySelector("[data-participant-logout]");
    const participantLinkWrap = document.querySelector("[data-participant-link-wrap]");
    const participantLinkEl = document.querySelector("[data-participant-link]");
    const participantStatusEl = document.querySelector("[data-participant-status]");
    const eventStatusLabel = document.querySelector("[data-event-status-label]");
    const eventStatusCopy = document.querySelector("[data-event-status-copy]");
    const eventCountdownEl = document.querySelector("[data-event-countdown]");
    const copyLinkBtn = document.querySelector("[data-copy-link]");
    const shareStatusEl = document.querySelector("[data-share-status]");
    const googleCalendarLink = document.querySelector("[data-google-calendar]");
    const icsDownloadLink = document.querySelector("[data-ics-download]");

    const BANNER_PREFIX = "/api/media/banner/";
    const BANNER_UUID =
      /^[0-9a-f]{8}-[0-9a-f]{4}-4[0-9a-f]{3}-[89ab][0-9a-f]{3}-[0-9a-f]{12}$/i;

    const state = {
      event: null,
      gallery: [],
      winners: null,
      resultsPublished: false,
      participantEventId: "",
      participantEmail: "",
      votedSubmissionIds: new Set()
    };

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const setStatus = (el, message, tone = "") => {
      if (!el) return;
      if (!message) {
        el.textContent = "";
        el.classList.add("hidden");
        el.classList.remove("!text-lime", "!text-coral", "!text-sky");
        return;
      }
      el.textContent = message;
      el.classList.remove("hidden", "!text-lime", "!text-coral", "!text-sky");
      if (tone) el.classList.add(tone);
    };

    const isBannerImageSrc = (value) => {
      const s = String(value).trim();
      if (!s) return false;
      if (s.startsWith(BANNER_PREFIX)) {
        return BANNER_UUID.test(s.slice(BANNER_PREFIX.length));
      }
      try {
        const u = new URL(s);
        return u.protocol === "http:" || u.protocol === "https:";
      } catch {
        return false;
      }
    };

    const formatDate = (value) => {
      if (!value) return "TBD";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return new Intl.DateTimeFormat(undefined, {
        month: "short",
        day: "numeric",
        year: "numeric"
      }).format(date);
    };

    const formatDateTimeForCalendar = (value) => {
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return "";
      const pad = (input) => String(input).padStart(2, "0");
      return `${date.getUTCFullYear()}${pad(date.getUTCMonth() + 1)}${pad(date.getUTCDate())}T${pad(
        date.getUTCHours()
      )}${pad(date.getUTCMinutes())}${pad(date.getUTCSeconds())}Z`;
    };

    const asDateValue = (value) => {
      const date = new Date(value);
      const time = date.getTime();
      return Number.isNaN(time) ? null : time;
    };

    const formatDuration = (ms) => {
      const totalHours = Math.max(0, Math.floor(ms / (1000 * 60 * 60)));
      const days = Math.floor(totalHours / 24);
      const hours = totalHours % 24;
      if (days > 0) return `${days}d ${hours}h`;
      return `${hours}h`;
    };

    const updateEventStatus = () => {
      if (!state.event) return;
      const now = Date.now();
      const applicationDeadline = asDateValue(state.event.applicationDeadline);
      const startDate = asDateValue(state.event.startDate);
      const endDate = asDateValue(state.event.endDate);

      let label = "Open";
      let copy = "Event details are live. Plan your project and timelines.";
      let countdown = "";

      if (applicationDeadline !== null && now <= applicationDeadline) {
        label = "Applications Open";
        copy = "Applications are currently open for participants.";
        countdown = `Deadline in ${formatDuration(applicationDeadline - now)}`;
      } else if (startDate !== null && now < startDate) {
        label = "Starting Soon";
        copy = "Application window may be closed. Event kickoff is approaching.";
        countdown = `Starts in ${formatDuration(startDate - now)}`;
      } else if (startDate !== null && endDate !== null && now >= startDate && now <= endDate) {
        label = "Live Now";
        copy = "Build phase is active. Submit before the event closes.";
        countdown = `Ends in ${formatDuration(endDate - now)}`;
      } else if (endDate !== null && now > endDate) {
        label = "Ended";
        copy = "This event has ended. Check results and project gallery.";
      }

      if (eventStatusLabel) eventStatusLabel.textContent = label;
      if (eventStatusCopy) eventStatusCopy.textContent = copy;
      if (eventCountdownEl) {
        eventCountdownEl.textContent = countdown;
        eventCountdownEl.classList.toggle("hidden", !countdown);
      }
    };

    const updateCalendarLinks = () => {
      if (!state.event) return;
      const title = String(state.event.title || "Hatch Event");
      const details = String(state.event.description || state.event.tagline || "");
      const location = String(state.event.location || "");
      const startDate = new Date(state.event.startDate || "");
      const endDate = new Date(state.event.endDate || "");
      if (Number.isNaN(startDate.getTime()) || Number.isNaN(endDate.getTime())) {
        if (googleCalendarLink) googleCalendarLink.classList.add("hidden");
        if (icsDownloadLink) icsDownloadLink.classList.add("hidden");
        return;
      }

      const googleDates = `${formatDateTimeForCalendar(startDate.toISOString())}/${formatDateTimeForCalendar(
        endDate.toISOString()
      )}`;
      const googleUrl = new URL("https://calendar.google.com/calendar/render");
      googleUrl.searchParams.set("action", "TEMPLATE");
      googleUrl.searchParams.set("text", title);
      googleUrl.searchParams.set("details", details);
      googleUrl.searchParams.set("location", location);
      googleUrl.searchParams.set("dates", googleDates);

      if (googleCalendarLink) {
        googleCalendarLink.href = googleUrl.toString();
        googleCalendarLink.classList.remove("hidden");
      }

      const icsContent = [
        "BEGIN:VCALENDAR",
        "VERSION:2.0",
        "PRODID:-//Hatch//Hackathon//EN",
        "BEGIN:VEVENT",
        `UID:${String(state.event.id || slug)}@hatch`,
        `DTSTAMP:${formatDateTimeForCalendar(new Date().toISOString())}`,
        `DTSTART:${formatDateTimeForCalendar(startDate.toISOString())}`,
        `DTEND:${formatDateTimeForCalendar(endDate.toISOString())}`,
        `SUMMARY:${title.replace(/\n/g, " ")}`,
        `DESCRIPTION:${details.replace(/\n/g, " ")}`,
        `LOCATION:${location.replace(/\n/g, " ")}`,
        "END:VEVENT",
        "END:VCALENDAR"
      ].join("\r\n");
      const blob = new Blob([icsContent], { type: "text/calendar;charset=utf-8" });
      const objectUrl = URL.createObjectURL(blob);
      if (icsDownloadLink) {
        icsDownloadLink.href = objectUrl;
        icsDownloadLink.download = `${String(state.event.slug || slug || "event")}.ics`;
        icsDownloadLink.classList.remove("hidden");
      }
    };

    const winnerBadges = (project) => {
      const badges = [];
      const scopes = Array.isArray(project.winnerScopes) ? project.winnerScopes : [];
      if (scopes.includes("overall")) badges.push("Overall Winner");
      scopes
        .filter((scope) => scope.startsWith("track:"))
        .forEach((scope) => badges.push(`Track Winner (${scope.slice(6)})`));
      if (project.isPopularityWinner) badges.push("People's Choice");
      return badges;
    };

    const renderParticipantAuth = () => {
      if (participantAuthCard) {
        participantAuthCard.classList.toggle("hidden", !state.resultsPublished);
      }
      if (!state.resultsPublished) {
        return;
      }
      const loggedIn = Boolean(state.participantEmail);
      if (participantEmailEl) {
        if (loggedIn) {
          participantEmailEl.textContent = state.participantEmail;
          participantEmailEl.classList.remove("hidden");
        } else {
          participantEmailEl.classList.add("hidden");
          participantEmailEl.textContent = "";
        }
      }
      if (participantLogoutBtn) {
        participantLogoutBtn.classList.toggle("hidden", !loggedIn);
      }
      if (participantLoginForm) {
        participantLoginForm.classList.toggle("hidden", loggedIn);
      }
    };

    const renderGallery = () => {
      if (!galleryEl) return;

      if (!state.resultsPublished) {
        galleryEl.innerHTML =
          '<div class="card !p-12 text-cream/35 italic border-dashed">Project gallery will unlock when results are published by organizers.</div>';
        return;
      }

      if (!Array.isArray(state.gallery) || state.gallery.length === 0) {
        galleryEl.innerHTML =
          '<div class="card !p-12 text-cream/35 italic border-dashed">No projects have been published yet.</div>';
        return;
      }

      galleryEl.innerHTML = state.gallery
        .map((project) => {
          const badges = winnerBadges(project);
          const voted = state.votedSubmissionIds.has(project.id);
          const canVote = Boolean(state.participantEmail);
          const voteLabel = voted ? "Remove Vote" : "Vote";
          const voteButton = canVote
            ? `<button class="btn-ghost !px-4 !py-2 !text-xs" type="button" data-vote-btn data-submission-id="${escapeHtml(project.id)}" data-voted="${voted ? "1" : "0"}">${voteLabel}</button>`
            : '<span class="text-xs text-cream/40">Sign in as participant to vote</span>';

          return `
            <article class="card !p-8 space-y-5">
              <div class="flex flex-col gap-4 md:flex-row md:items-start md:justify-between">
                <div>
                  <h3 class="text-2xl font-bold">${escapeHtml(project.projectName || "Untitled project")}</h3>
                  <p class="text-sm text-cream/45 mt-1">${escapeHtml(project.teamName || "")}</p>
                  ${
                    project.track && String(project.track).trim()
                      ? `<p class="text-xs font-bold uppercase tracking-widest text-cream/35 mt-2">Track · ${escapeHtml(
                          String(project.track).trim()
                        )}</p>`
                      : ""
                  }
                </div>
                <span class="status-pill !bg-cream/5 !border-cream/10">${escapeHtml(project.voteCount ?? 0)} votes</span>
              </div>
              <p class="text-sm text-cream/60 leading-relaxed">${escapeHtml(project.description || "")}</p>
              <div class="flex flex-wrap gap-2">
                ${badges
                  .map(
                    (badge) =>
                      `<span class="status-pill !bg-lime/10 !text-lime !border-lime/20">${escapeHtml(
                        badge
                      )}</span>`
                  )
                  .join("")}
              </div>
              <div class="flex flex-wrap items-center justify-between gap-3 pt-2">
                <div class="flex flex-wrap gap-3">
                  ${
                    project.repoUrl
                      ? `<a class="btn-ghost !px-4 !py-2 !text-xs" href="${escapeHtml(
                          project.repoUrl
                        )}" target="_blank" rel="noreferrer">Repo</a>`
                      : ""
                  }
                  ${
                    project.demoUrl
                      ? `<a class="btn-ghost !px-4 !py-2 !text-xs" href="${escapeHtml(
                          project.demoUrl
                        )}" target="_blank" rel="noreferrer">Demo</a>`
                      : ""
                  }
                </div>
                ${voteButton}
              </div>
            </article>
          `;
        })
        .join("");

      galleryEl.querySelectorAll("[data-vote-btn]").forEach((button) => {
        button.addEventListener("click", async () => {
          const submissionId = button.getAttribute("data-submission-id");
          const voted = button.getAttribute("data-voted") === "1";
          if (!submissionId) return;

          try {
            const response = await fetch(`/api/participants/events/${slug}/votes${querySuffix}`, {
              method: voted ? "DELETE" : "POST",
              headers: { "content-type": "application/json" },
              body: JSON.stringify({ submissionId })
            });
            const payload = await response.json().catch(() => ({}));
            if (!response.ok) throw new Error(payload.error || "Unable to update vote.");
            setStatus(participantStatusEl, voted ? "Vote removed." : "Vote recorded.", "!text-lime");
            await loadParticipantVotes();
            await loadEvent();
          } catch (error) {
            setStatus(participantStatusEl, error.message, "!text-coral");
          }
        });
      });
    };

    const loadParticipant = async () => {
      try {
        const response = await fetch("/api/participants/me");
        const payload = await response.json().catch(() => ({ participant: null }));
        if (!response.ok) throw new Error("Unable to load participant session.");
        const participantEventId = String(payload.participant?.eventId || "");
        state.participantEventId = participantEventId;
        state.participantEmail =
          participantEventId && participantEventId === String(state.event?.id || "")
            ? payload.participant?.email || ""
            : "";
        renderParticipantAuth();
        if (state.participantEmail) {
          await loadParticipantVotes();
        } else {
          state.votedSubmissionIds = new Set();
        }
        renderGallery();
      } catch {
        state.participantEventId = "";
        state.participantEmail = "";
        state.votedSubmissionIds = new Set();
        renderParticipantAuth();
        renderGallery();
      }
    };

    const loadParticipantVotes = async () => {
      if (!state.participantEmail || !slug) {
        state.votedSubmissionIds = new Set();
        return;
      }
      try {
        const response = await fetch(`/api/participants/events/${slug}/votes${querySuffix}`);
        if (!response.ok) {
          state.votedSubmissionIds = new Set();
          return;
        }
        const payload = await response.json();
        state.votedSubmissionIds = new Set(payload.votedSubmissionIds || []);
      } catch {
        state.votedSubmissionIds = new Set();
      }
    };

    const renderTracks = (tracks) => {
      if (!tracksEl) return;
      if (tracks && tracks.length > 0) {
        tracksEl.innerHTML = tracks
          .map(
            (track) => `
            <div class="card !p-10 group hover:border-lime/30 transition-all">
              <div class="flex flex-col md:flex-row md:items-start justify-between gap-6">
                <div class="space-y-4">
                  <h3 class="text-2xl font-bold">${escapeHtml(track.name)}</h3>
                  <p class="text-cream/50 leading-relaxed">${escapeHtml(track.description || "")}</p>
                </div>
                ${
                  track.prize
                    ? `
                  <div class="shrink-0 bg-lime/10 border border-lime/20 px-6 py-4 rounded-2xl">
                    <span class="text-xs font-bold uppercase tracking-widest text-lime block mb-1">Prize pool</span>
                    <span class="text-xl font-bold text-cream">${escapeHtml(track.prize)}</span>
                  </div>
                `
                    : ""
                }
              </div>
            </div>
          `
          )
          .join("");
      } else {
        tracksEl.innerHTML =
          '<div class="card !p-12 text-cream/40 text-center italic">Tracks will be announced once the system stabilizes.</div>';
      }
    };

    const renderFaqs = (faqs) => {
      if (!faqsEl) return;
      if (faqs && faqs.length > 0) {
        faqsEl.innerHTML = faqs
          .map(
            (faq) => `
            <details class="card group !p-0 overflow-hidden border-cream/5 bg-cream/[0.02]">
              <summary class="flex items-center justify-between p-8 cursor-pointer list-none">
                <span class="text-lg font-bold group-hover:text-violet transition-colors">${escapeHtml(
                  faq.question
                )}</span>
                <svg xmlns="http://www.w3.org/2000/svg" class="w-5 h-5 text-cream/30 transition-transform duration-300" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="3" stroke-linecap="round" stroke-linejoin="round"><polyline points="6 9 12 15 18 9"></polyline></svg>
              </summary>
              <div class="px-8 pb-8 text-cream/50 leading-relaxed border-t border-cream/5 pt-6">
                ${escapeHtml(faq.answer)}
              </div>
            </details>
          `
          )
          .join("");
      } else {
        faqsEl.innerHTML =
          '<div class="card !p-12 text-cream/40 text-center italic">FAQ updates are currently in development.</div>';
      }
    };

    const loadEvent = async () => {
      if (!slug) return;
      try {
        const response = await fetch(`/api/events/${slug}${querySuffix}`);
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || "Event not found.");
        const { event, tracks, faqs, resultsPublished, gallery, winners } = payload;
        state.event = event;
        state.gallery = Array.isArray(gallery) ? gallery : [];
        state.winners = winners || null;
        state.resultsPublished = Boolean(resultsPublished);

        if (titleEl) titleEl.textContent = event.title;
        if (taglineEl) taglineEl.textContent = event.tagline || "";
        if (bannerWrap && bannerImg && event.bannerUrl && isBannerImageSrc(String(event.bannerUrl))) {
          bannerImg.src = String(event.bannerUrl);
          bannerImg.alt = `${event.title} banner`;
          bannerWrap.classList.remove("hidden");
        }
        if (descEl)
          descEl.textContent =
            event.description || "The organizer hasn't shared a full description yet.";
        if (modeEl) modeEl.textContent = event.mode || "Hackathon";

        if (orgEl && event.organizationName) {
          orgEl.textContent = `Hosted by ${event.organizationName}`;
          orgEl.classList.remove("hidden");
        }

        if (metaEl) {
          metaEl.innerHTML = `
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-violet"><rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect><line x1="16" y1="2" x2="16" y2="6"></line><line x1="8" y1="2" x2="8" y2="6"></line><line x1="3" y1="10" x2="21" y2="10"></line></svg>
              ${formatDate(event.startDate)} – ${formatDate(event.endDate)}
            </div>
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-sky"><path d="M21 10c0 7-9 13-9 13s-9-6-9-13a9 9 0 0 1 18 0z"></path><circle cx="12" cy="10" r="3"></circle></svg>
              ${escapeHtml(event.location || "Location TBD")}
            </div>
            <div class="flex items-center gap-3">
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-coral"><polyline points="22 12 18 12 15 21 9 3 6 12 2 12"></polyline></svg>
              Apply by ${formatDate(event.applicationDeadline)}
            </div>
          `;
        }

        if (socialsEl && socialsCard) {
          const items = [];
          if (event.websiteUrl) {
            items.push(`<a href="${escapeHtml(event.websiteUrl)}" target="_blank" class="text-sm text-cream hover:text-lime transition-colors">Website</a>`);
          }
          if (event.twitterUrl) {
            items.push(`<a href="${escapeHtml(event.twitterUrl)}" target="_blank" class="text-sm text-cream hover:text-lime transition-colors">Twitter/X</a>`);
          }
          if (event.discordUrl) {
            items.push(`<a href="${escapeHtml(event.discordUrl)}" target="_blank" class="text-sm text-cream hover:text-lime transition-colors">Discord</a>`);
          }
          if (items.length > 0) {
            socialsEl.innerHTML = items.join("");
            socialsCard.classList.remove("hidden");
          } else {
            socialsCard.classList.add("hidden");
          }
        }

        if (applyLink) applyLink.href = `${routeBase}/apply`;
        if (submitLink) submitLink.href = `${routeBase}/submit`;

        renderTracks(tracks);
        renderFaqs(faqs);
        renderGallery();
        updateEventStatus();
        updateCalendarLinks();
      } catch (error) {
        if (titleEl) titleEl.textContent = "Signal Lost";
        if (descEl)
          descEl.textContent =
            "We couldn't synchronize with this event's data. It may be unpublished or non-existent.";
        if (tracksEl) tracksEl.innerHTML = "";
        if (faqsEl) faqsEl.innerHTML = "";
        if (galleryEl) galleryEl.innerHTML = "";
      }
    };

    participantLoginForm?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!slug) return;
      const formData = new FormData(participantLoginForm);
      const email = String(formData.get("email") || "").trim();
      if (!email) {
        setStatus(participantStatusEl, "Enter an email.", "!text-coral");
        return;
      }
      try {
        setStatus(participantStatusEl, "Generating link...", "!text-sky");
        const response = await fetch(`/api/participants/events/${slug}/request-magic-link${querySuffix}`, {
          method: "POST",
          headers: { "content-type": "application/json" },
          body: JSON.stringify({ email })
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || "Unable to generate magic link.");

        if (participantLinkWrap && participantLinkEl) {
          participantLinkEl.href = payload.verifyUrl || "#";
          participantLinkWrap.classList.remove("hidden");
        }
        setStatus(participantStatusEl, "Magic link ready. Open it to sign in.", "!text-lime");
      } catch (error) {
        setStatus(participantStatusEl, error.message, "!text-coral");
      }
    });

    participantLogoutBtn?.addEventListener("click", async () => {
      await fetch("/api/participants/logout", { method: "POST" });
      state.participantEventId = "";
      state.participantEmail = "";
      state.votedSubmissionIds = new Set();
      renderParticipantAuth();
      renderGallery();
      setStatus(participantStatusEl, "Signed out", "!text-lime");
    });

    copyLinkBtn?.addEventListener("click", async () => {
      try {
        await navigator.clipboard.writeText(window.location.href);
        if (shareStatusEl) {
          shareStatusEl.textContent = "Copied event link.";
          shareStatusEl.classList.remove("hidden");
        }
      } catch {
        if (shareStatusEl) {
          shareStatusEl.textContent = "Unable to copy automatically. Copy from your address bar.";
          shareStatusEl.classList.remove("hidden");
        }
      }
    });

    const init = async () => {
      await loadEvent();
      updateEventStatus();
      window.setInterval(updateEventStatus, 60_000);
      if (state.resultsPublished) {
        await loadParticipant();
      } else {
        state.participantEmail = "";
        state.votedSubmissionIds = new Set();
        renderParticipantAuth();
      }
    };

    init();
  </script>
</BaseLayout>
