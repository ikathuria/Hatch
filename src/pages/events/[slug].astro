---
import BaseLayout from "../../layouts/BaseLayout.astro";
---

<BaseLayout title="Event | Hatch">
  <section class="mx-auto w-full max-w-6xl px-6 py-16">
    <div class="card space-y-6">
      <div>
        <span class="eyebrow" data-event-mode>Hackathon</span>
        <h1 class="mt-4 text-3xl font-semibold md:text-5xl" data-event-title>
          Loading event…
        </h1>
        <p class="mt-3 text-cream-70" data-event-tagline></p>
        <div class="mt-6 flex flex-wrap gap-4 text-sm text-cream-70" data-event-meta></div>
      </div>
      <p class="text-cream-75" data-event-description></p>
      <div class="flex flex-wrap gap-4">
        <a class="btn-primary" data-apply-link href="#">Apply</a>
        <a class="btn-ghost" data-submit-link href="#">Submit project</a>
      </div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-10">
    <h2 class="section-title">Tracks</h2>
    <div class="grid gap-4 md:grid-cols-2" data-event-tracks>
      <div class="card text-cream-70">Loading tracks…</div>
    </div>
  </section>

  <section class="mx-auto w-full max-w-6xl px-6 py-10">
    <h2 class="section-title">FAQ</h2>
    <div class="grid gap-4 md:grid-cols-2" data-event-faqs>
      <div class="card text-cream-70">Loading FAQ…</div>
    </div>
  </section>

  <script>
    const slug = window.location.pathname.split("/").filter(Boolean).pop();
    const titleEl = document.querySelector("[data-event-title]");
    const taglineEl = document.querySelector("[data-event-tagline]");
    const descEl = document.querySelector("[data-event-description]");
    const metaEl = document.querySelector("[data-event-meta]");
    const modeEl = document.querySelector("[data-event-mode]");
    const tracksEl = document.querySelector("[data-event-tracks]");
    const faqsEl = document.querySelector("[data-event-faqs]");
    const applyLink = document.querySelector("[data-apply-link]");
    const submitLink = document.querySelector("[data-submit-link]");

    const formatDate = (value) => {
      if (!value) return "TBD";
      const date = new Date(value);
      if (Number.isNaN(date.getTime())) return value;
      return new Intl.DateTimeFormat(undefined, {
        month: "short",
        day: "numeric",
        year: "numeric"
      }).format(date);
    };

    const renderList = (items, render, fallback) => {
      if (!items || items.length === 0) {
        return `<div class="card text-cream-70">${fallback}</div>`;
      }
      return items.map(render).join("");
    };

    const loadEvent = async () => {
      if (!slug) return;
      try {
        const response = await fetch(`/api/events/${slug}`);
        if (!response.ok) throw new Error("Event not found.");
        const { event, tracks, faqs } = await response.json();

        if (titleEl) titleEl.textContent = event.title;
        if (taglineEl) taglineEl.textContent = event.tagline || "";
        if (descEl) descEl.textContent = event.description || "";
        if (modeEl) modeEl.textContent = event.mode || "Hackathon";
        if (metaEl) {
          metaEl.innerHTML = `
            <span>${formatDate(event.startDate)} – ${formatDate(event.endDate)}</span>
            <span>•</span>
            <span>${event.location || "Location TBD"}</span>
            <span>•</span>
            <span>Apply by ${formatDate(event.applicationDeadline)}</span>
          `;
        }

        if (applyLink) applyLink.href = `/events/${slug}/apply`;
        if (submitLink) submitLink.href = `/events/${slug}/submit`;

        if (tracksEl) {
          tracksEl.innerHTML = renderList(
            tracks,
            (track) => `
              <div class="card">
                <h3 class="text-xl font-semibold">${track.name}</h3>
                <p class="mt-3 text-cream-70">${track.description || ""}</p>
                <p class="mt-5 text-sm text-[color:var(--lime)]">${track.prize || ""}</p>
              </div>
            `,
            "Tracks will be announced soon."
          );
        }

        if (faqsEl) {
          faqsEl.innerHTML = renderList(
            faqs,
            (faq) => `
              <details class="card">
                <summary class="cursor-pointer text-lg font-semibold">${faq.question}</summary>
                <p class="mt-3 text-cream-70">${faq.answer}</p>
              </details>
            `,
            "FAQ updates coming soon."
          );
        }
      } catch (error) {
        if (titleEl) titleEl.textContent = "Event not found";
        if (descEl) descEl.textContent = "This event may be private or unpublished.";
        if (tracksEl) tracksEl.innerHTML = "";
        if (faqsEl) faqsEl.innerHTML = "";
      }
    };

    loadEvent();
  </script>
</BaseLayout>
