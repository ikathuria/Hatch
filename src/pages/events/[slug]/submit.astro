---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Submit Project | Hatch">
  <section class="mx-auto w-full max-w-4xl px-6 py-12">
    <div class="card !p-8 md:!p-10">
      <div class="mb-8 space-y-3">
        <div class="flex items-center gap-3">
          <a
            href="#"
            data-back-link
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-cream/5 transition-colors hover:bg-cream/10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </a>
          <span class="eyebrow !border-violet/20 !bg-violet/10 !text-violet">Project submission</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl" data-event-title>Submit your project</h1>
        <p class="text-cream/55" data-event-tagline>Share your final build for judging.</p>
      </div>

      <div class="mb-8 hidden rounded-2xl border border-sky/20 bg-sky/10 p-5" data-auth-gate>
        <p class="text-xs font-bold uppercase tracking-widest text-sky">Participant access required</p>
        <p class="mt-2 text-sm leading-relaxed text-cream/70" data-auth-message>
          Apply to this event first to unlock project submission.
        </p>
        <div class="mt-4 flex flex-wrap items-center gap-3">
          <a class="btn-primary !px-5 !py-3 !text-sm" data-apply-link href="#">Apply to participate</a>
          <button class="btn-ghost !px-4 !py-2 !text-xs hidden" data-participant-logout type="button">Sign out</button>
        </div>
        <span class="mt-3 block text-xs text-cream/50 hidden" data-participant-email></span>
        <span class="status-pill mt-3 hidden !border-none !bg-transparent !p-0 !text-xs" data-auth-status role="status" aria-live="polite"></span>
      </div>

      <form class="space-y-8" data-form>
        <fieldset class="space-y-8" data-submit-fieldset disabled>
          <div class="grid gap-6 md:grid-cols-2">
            <label class="space-y-2">
              <span class="form-label">Team name <span class="text-coral">*</span></span>
              <input class="input-field" name="teamName" required placeholder="Nova Force" />
            </label>

            <label class="space-y-2">
              <span class="form-label">Project name <span class="text-coral">*</span></span>
              <input class="input-field" name="projectName" required placeholder="Neural Bridge" />
            </label>

            <label class="space-y-2">
              <span class="form-label">Track <span class="text-coral">*</span></span>
              <select class="input-field" name="track" required data-track-select>
                <option value="">Select track</option>
              </select>
            </label>

            <label class="space-y-2">
              <span class="form-label">Contact email <span class="text-coral">*</span></span>
              <input class="input-field" type="email" name="contactEmail" required placeholder="lead@team.com" />
            </label>

            <label class="space-y-2">
              <span class="form-label">Repository URL</span>
              <input class="input-field" type="url" name="repoUrl" placeholder="https://github.com/your-repo" />
              <span class="text-xs text-cream/45">Must start with `https://github.com/` or `github.com/`.</span>
            </label>

            <label class="space-y-2">
              <span class="form-label">Demo URL</span>
              <input class="input-field" type="url" name="demoUrl" placeholder="https://your-demo.app" />
            </label>

            <label class="space-y-2 md:col-span-2">
              <span class="form-label">Slides URL</span>
              <input class="input-field" type="url" name="deckUrl" placeholder="https://your-pitch-deck" />
            </label>
          </div>

          <label class="space-y-2">
            <span class="form-label">Project description <span class="text-coral">*</span></span>
            <textarea class="input-field" name="description" rows="5" required placeholder="What did you build and why does it matter?"></textarea>
          </label>

          <label class="space-y-2">
            <span class="form-label">Team members (names + emails) <span class="text-coral">*</span></span>
            <textarea class="input-field" name="members" rows="4" required placeholder="Avery P. - avery@io.com"></textarea>
          </label>

          <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
            <span class="status-pill hidden !border-none !bg-transparent !p-0 text-sm" data-status role="status" aria-live="polite"></span>
            <button class="btn-primary !px-10 !py-3.5" type="submit">Submit project</button>
          </div>
        </fieldset>
      </form>
    </div>
  </section>

  <script>
    import { uiCopy } from "../../../content/microcopy";

    const pathParts = window.location.pathname.split("/").filter(Boolean);
    const hasOrganizerScopedPath = pathParts[0] === "events" && pathParts.length >= 4;
    const slug = hasOrganizerScopedPath ? pathParts[2] : pathParts[1] || "";
    const organizerId = hasOrganizerScopedPath ? pathParts[1] : "";
    const routeBase = organizerId ? `/events/${organizerId}/${slug}` : `/events/${slug}`;
    const querySuffix = organizerId ? `?organizerId=${encodeURIComponent(organizerId)}` : "";

    const backLink = document.querySelector("[data-back-link]");
    const applyLink = document.querySelector("[data-apply-link]");
    const form = document.querySelector("[data-form]");
    const submitFieldset = document.querySelector("[data-submit-fieldset]");
    const status = document.querySelector("[data-status]");
    const titleEl = document.querySelector("[data-event-title]");
    const taglineEl = document.querySelector("[data-event-tagline]");
    const trackSelect = document.querySelector("[data-track-select]");
    const button = form?.querySelector("button[type='submit']");
    const defaultLabel = button?.textContent || "Submit project";
    const contactEmailInput = form?.querySelector("input[name='contactEmail']");

    const authGate = document.querySelector("[data-auth-gate]");
    const authMessage = document.querySelector("[data-auth-message]");
    const authStatus = document.querySelector("[data-auth-status]");
    const participantEmailEl = document.querySelector("[data-participant-email]");
    const participantLogoutBtn = document.querySelector("[data-participant-logout]");

    if (backLink) backLink.href = routeBase;
    if (applyLink) applyLink.href = `${routeBase}/apply`;

    const state = {
      eventId: "",
      participantEmail: "",
      sessionEmail: "",
      hasForeignSession: false
    };

    const githubPattern = /^(https:\/\/github\.com\/.+|github\.com\/.+)$/i;

    const setStatus = (el, message, tone = "") => {
      if (!el) return;
      if (!message) {
        el.textContent = "";
        el.classList.add("hidden");
        el.classList.remove("!text-lime", "!text-coral", "!text-sky");
        return;
      }
      el.textContent = message;
      el.classList.remove("hidden", "!text-lime", "!text-coral", "!text-sky");
      if (tone) el.classList.add(tone);
    };

    const setSubmissionEnabled = (enabled) => {
      if (submitFieldset) submitFieldset.disabled = !enabled;
      if (!button) return;
      button.disabled = !enabled;
      if (!enabled) {
        button.textContent = "Participant access required";
      } else if (button.textContent !== "Submitted") {
        button.textContent = defaultLabel;
      }
    };

    const renderAuthGate = () => {
      const authorized = Boolean(state.participantEmail);
      if (authGate) authGate.classList.toggle("hidden", authorized);

      if (participantEmailEl) {
        if (state.sessionEmail) {
          participantEmailEl.textContent = `Signed in as ${state.sessionEmail}`;
          participantEmailEl.classList.remove("hidden");
        } else {
          participantEmailEl.classList.add("hidden");
          participantEmailEl.textContent = "";
        }
      }

      if (participantLogoutBtn) {
        participantLogoutBtn.classList.toggle("hidden", !state.sessionEmail);
      }

      if (authMessage) {
        if (state.hasForeignSession) {
          authMessage.textContent =
            "You are signed in for a different event. Sign out, then apply to this event to unlock submission.";
        } else {
          authMessage.textContent = uiCopy.public.detail.applyFirst;
        }
      }
    };

    const loadParticipant = async () => {
      try {
        const response = await fetch("/api/participants/me");
        const payload = await response.json().catch(() => ({ participant: null }));
        const participant = payload.participant || null;

        state.sessionEmail = participant?.email || "";
        state.hasForeignSession = Boolean(participant && participant.eventId !== state.eventId);
        state.participantEmail =
          participant && participant.eventId === state.eventId ? participant.email || "" : "";

        if (contactEmailInput && state.participantEmail) {
          contactEmailInput.value = state.participantEmail;
          contactEmailInput.readOnly = true;
          contactEmailInput.classList.add("opacity-80");
        } else if (contactEmailInput) {
          contactEmailInput.readOnly = false;
          contactEmailInput.classList.remove("opacity-80");
        }

        setSubmissionEnabled(Boolean(state.participantEmail));
        renderAuthGate();
      } catch {
        state.sessionEmail = "";
        state.hasForeignSession = false;
        state.participantEmail = "";
        setSubmissionEnabled(false);
        renderAuthGate();
      }
    };

    const loadEvent = async () => {
      try {
        const response = await fetch(`/api/events/${slug}${querySuffix}`);
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || "Event not found.");
        const { event, tracks } = payload;
        state.eventId = String(event?.id || "");

        if (titleEl) titleEl.textContent = `Submit for ${event.title}`;
        if (taglineEl) taglineEl.textContent = event.tagline || "";
        if (trackSelect) {
          trackSelect.innerHTML = '<option value="">Select track</option>';
          tracks.forEach((track) => {
            const option = document.createElement("option");
            option.value = track.name;
            option.textContent = track.name;
            trackSelect.appendChild(option);
          });
        }

        await loadParticipant();
      } catch {
        setStatus(status, "This event is not available right now.", "!text-coral");
        setSubmissionEnabled(false);
      }
    };

    participantLogoutBtn?.addEventListener("click", async () => {
      await fetch("/api/participants/logout", { method: "POST" });
      state.participantEmail = "";
      state.sessionEmail = "";
      state.hasForeignSession = false;
      setSubmissionEnabled(false);
      renderAuthGate();
      setStatus(authStatus, "Signed out", "!text-lime");
    });

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form) return;

      if (!state.participantEmail) {
        setSubmissionEnabled(false);
        renderAuthGate();
        setStatus(authStatus, uiCopy.participant.submit.gated, "!text-coral");
        return;
      }

      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus(status, "Complete all required fields before submitting.", "!text-coral");
        return;
      }

      const repoValue = String(form.repoUrl?.value || "").trim();
      if (repoValue && !githubPattern.test(repoValue)) {
        setStatus(status, "Repository URL must start with https://github.com/ or github.com/.", "!text-coral");
        form.repoUrl?.focus();
        return;
      }

      if (button) {
        button.disabled = true;
        button.classList.remove("btn-primary--success");
        button.textContent = "Submitting...";
      }
      setStatus(status, "", "");

      try {
        const response = await fetch(`/api/events/${slug}/submit${querySuffix}`, {
          method: "POST",
          body: new FormData(form)
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || "Unable to submit project.");
        }
        setStatus(status, uiCopy.participant.submit.success, "!text-lime");
        if (button) {
          button.textContent = "Submitted";
          button.classList.add("btn-primary--success");
        }
        window.setTimeout(() => {
          window.location.href = routeBase;
        }, 900);
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unable to submit project.";
        setStatus(status, message, "!text-coral");
        if (button) {
          button.disabled = false;
          button.classList.remove("btn-primary--success");
          button.textContent = defaultLabel;
        }
        if (message.toLowerCase().includes("sign in")) {
          await loadParticipant();
        }
      }
    });

    loadEvent();
  </script>
</BaseLayout>
