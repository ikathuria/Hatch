---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Apply to Participate | Hatch">
  <section class="mx-auto w-full max-w-4xl px-6 py-12">
    <div class="card !p-8 md:!p-10">
      <div class="mb-8 space-y-3">
        <div class="flex items-center gap-3">
          <a
            href="#"
            data-back-link
            class="flex h-8 w-8 items-center justify-center rounded-lg bg-cream/5 transition-colors hover:bg-cream/10"
          >
            <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
          </a>
          <span class="eyebrow !border-lime/20 !bg-lime/10 !text-lime">Participant application</span>
        </div>
        <h1 class="text-4xl font-bold tracking-tight md:text-5xl" data-event-title>Apply to participate</h1>
        <p class="text-cream/55" data-event-tagline>Tell organizers who you are and give them enough context to review your application.</p>
      </div>

      <form class="space-y-8" data-form>
        <div class="grid gap-6 md:grid-cols-2">
          <label class="space-y-2">
            <span class="form-label">Full name <span class="text-coral">*</span></span>
            <input class="input-field" name="fullName" required placeholder="Jordan Lee" />
          </label>

          <label class="space-y-2">
            <span class="form-label">Email <span class="text-coral">*</span></span>
            <input class="input-field" type="email" name="email" required placeholder="you@example.com" />
          </label>

          <label class="space-y-2">
            <span class="form-label">Location <span class="text-coral">*</span></span>
            <select class="input-field" name="location" required data-location-select>
              <option value="">Select location</option>
            </select>
          </label>

          <label class="space-y-2">
            <span class="form-label">Team status <span class="text-coral">*</span></span>
            <select class="input-field" name="teamStatus" required>
              <option value="">Select team status</option>
              <option>Solo and looking for teammates</option>
              <option>Already have a team</option>
              <option>Open to either</option>
            </select>
          </label>

          <label class="space-y-2">
            <span class="form-label">LinkedIn <span class="text-coral">*</span></span>
            <input class="input-field" name="linkedinUrl" required placeholder="https://linkedin.com/in/your-profile" />
          </label>

          <label class="space-y-2">
            <span class="form-label">GitHub <span class="text-coral">*</span></span>
            <input class="input-field" name="githubUrl" required placeholder="https://github.com/your-handle" />
          </label>
        </div>

        <div class="space-y-6 border-t border-cream/10 pt-6">
          <div class="hidden space-y-6" data-custom-fields></div>

          <label class="flex cursor-pointer items-start gap-3 rounded-xl border border-cream/10 bg-cream/5 p-4">
            <input type="checkbox" name="consent" required class="mt-1 h-5 w-5 rounded accent-lime" />
            <span class="text-sm text-cream/65">
              I agree to the <a class="font-semibold text-lime hover:underline" href="/code-of-conduct">Code of conduct</a>
              and event rules. <span class="text-coral">*</span>
            </span>
          </label>
        </div>

        <div class="flex flex-col gap-4 md:flex-row md:items-center md:justify-between">
          <span class="status-pill hidden !border-none !bg-transparent !p-0 text-sm" data-status role="status" aria-live="polite"></span>
          <button class="btn-primary !px-10 !py-3.5" type="submit">Submit application</button>
        </div>
      </form>
    </div>
  </section>

  <script>
    import { uiCopy } from "../../../content/microcopy";

    const pathParts = window.location.pathname.split("/").filter(Boolean);
    const hasOrganizerScopedPath = pathParts[0] === "events" && pathParts.length >= 4;
    const slug = hasOrganizerScopedPath ? pathParts[2] : pathParts[1] || "";
    const organizerId = hasOrganizerScopedPath ? pathParts[1] : "";
    const routeBase = organizerId ? `/events/${organizerId}/${slug}` : `/events/${slug}`;
    const querySuffix = organizerId ? `?organizerId=${encodeURIComponent(organizerId)}` : "";

    const backLink = document.querySelector("[data-back-link]");
    const form = document.querySelector("[data-form]");
    const status = document.querySelector("[data-status]");
    const titleEl = document.querySelector("[data-event-title]");
    const taglineEl = document.querySelector("[data-event-tagline]");
    const locationSelect = document.querySelector("[data-location-select]");
    const customFieldsEl = document.querySelector("[data-custom-fields]");
    const button = form?.querySelector("button[type='submit']");
    const defaultLabel = button?.textContent || "Submit application";
    const fullNameInput = form?.querySelector("input[name='fullName']");
    const emailInput = form?.querySelector("input[name='email']");

    if (backLink) backLink.href = routeBase;

    const emailPattern = /^[^\s@]+@[^\s@]+\.[^\s@]+$/;
    const slugify = (value) =>
      String(value || "")
        .toLowerCase()
        .trim()
        .replace(/[^a-z0-9]+/g, "-")
        .replace(/^-+|-+$/g, "");
    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const setStatus = (message, tone = "") => {
      if (!status) return;
      if (!message) {
        status.textContent = "";
        status.classList.add("hidden");
        status.classList.remove("!text-lime", "!text-coral", "!text-sky");
        return;
      }
      status.textContent = message;
      status.classList.remove("hidden", "!text-lime", "!text-coral", "!text-sky");
      if (tone) status.classList.add(tone);
    };

    const prefillIdentity = async (eventId) => {
      const rememberedName = window.localStorage.getItem("hatch.participant.name") || "";
      const rememberedEmail = window.localStorage.getItem("hatch.participant.email") || "";

      if (fullNameInput && rememberedName && !String(fullNameInput.value || "").trim()) {
        fullNameInput.value = rememberedName;
      }
      if (emailInput && rememberedEmail && !String(emailInput.value || "").trim()) {
        emailInput.value = rememberedEmail;
      }

      const [participantResult, organizerResult] = await Promise.allSettled([
        fetch("/api/participants/me"),
        fetch("/api/auth/me")
      ]);

      if (participantResult.status === "fulfilled" && participantResult.value.ok) {
        const payload = await participantResult.value.json().catch(() => ({ participant: null }));
        const participant = payload.participant || null;
        if (participant && String(participant.eventId || "") === String(eventId || "")) {
          if (emailInput) {
            emailInput.value = String(participant.email || "");
            emailInput.readOnly = true;
            emailInput.classList.add("opacity-80");
          }
        }
      }

      if (organizerResult.status === "fulfilled" && organizerResult.value.ok) {
        const payload = await organizerResult.value.json().catch(() => ({ organizer: null }));
        const organizer = payload.organizer || null;
        if (fullNameInput && organizer?.name && !String(fullNameInput.value || "").trim()) {
          fullNameInput.value = String(organizer.name);
        }
        if (emailInput && organizer?.email && !String(emailInput.value || "").trim()) {
          emailInput.value = String(organizer.email);
        }
      }
    };

    const renderCustomFields = (fields) => {
      if (!customFieldsEl) return;
      if (!Array.isArray(fields) || fields.length === 0) {
        customFieldsEl.innerHTML = "";
        customFieldsEl.classList.add("hidden");
        return;
      }

      customFieldsEl.classList.remove("hidden");
      customFieldsEl.innerHTML = fields
        .map((field, index) => {
          const fieldId = slugify(field?.id || field?.label || `question-${index + 1}`);
          const label = String(field?.label || "").trim();
          const helper = String(field?.helperText || "").trim();
          const required = Boolean(field?.required);
          const requiredAttr = required ? "required" : "";
          const requiredMark = required ? '<span class="text-coral">*</span>' : "";

          if (String(field?.type || "text") === "textarea") {
            return `
              <label class="space-y-2">
                <span class="form-label">${escapeHtml(label)} ${requiredMark}</span>
                ${helper ? `<span class="block text-sm text-cream/45">${escapeHtml(helper)}</span>` : ""}
                <textarea class="input-field" name="customField:${fieldId}" rows="4" ${requiredAttr}></textarea>
              </label>
            `;
          }

          if (String(field?.type || "text") === "select") {
            const options = Array.isArray(field?.options) ? field.options : [];
            return `
              <label class="space-y-2">
                <span class="form-label">${escapeHtml(label)} ${requiredMark}</span>
                ${helper ? `<span class="block text-sm text-cream/45">${escapeHtml(helper)}</span>` : ""}
                <select class="input-field" name="customField:${fieldId}" ${requiredAttr}>
                  <option value="">Select an option</option>
                  ${options
                    .map((option) => `<option value="${escapeHtml(option)}">${escapeHtml(option)}</option>`)
                    .join("")}
                </select>
              </label>
            `;
          }

          return `
            <label class="space-y-2">
              <span class="form-label">${escapeHtml(label)} ${requiredMark}</span>
              ${helper ? `<span class="block text-sm text-cream/45">${escapeHtml(helper)}</span>` : ""}
              <input class="input-field" name="customField:${fieldId}" ${requiredAttr} />
            </label>
          `;
        })
        .join("");
    };

    const loadEvent = async () => {
      try {
        const response = await fetch(`/api/events/${slug}${querySuffix}`);
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || "Event not found.");
        const { event } = payload;
        if (titleEl) titleEl.textContent = `Apply to ${event.title}`;
        if (taglineEl) taglineEl.textContent = event.tagline || "";
        renderCustomFields(Array.isArray(event?.applicationFormFields) ? event.applicationFormFields : []);
        if (locationSelect) {
          const configuredLocations = Array.isArray(event?.participantLocations)
            ? event.participantLocations
            : [];
          const availableLocations =
            configuredLocations.length > 0
              ? configuredLocations
              : event?.location
                ? [event.location]
                : [];

          locationSelect.innerHTML = '<option value="">Select location</option>';
          availableLocations.forEach((location) => {
            const option = document.createElement("option");
            option.value = location;
            option.textContent = location;
            locationSelect.appendChild(option);
          });
          if (availableLocations.length === 0 && button) {
            button.disabled = true;
            setStatus("Organizer needs to add participant locations before applications can open.", "!text-coral");
          }
        }
        await prefillIdentity(event?.id || "");
      } catch {
        setStatus("This event is not available right now.", "!text-coral");
        if (button) button.disabled = true;
      }
    };

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!form) return;

      if (!form.checkValidity()) {
        form.reportValidity();
        setStatus("Complete all required fields before submitting.", "!text-coral");
        return;
      }

      const emailValue = String(emailInput?.value || "").trim();
      if (!emailPattern.test(emailValue)) {
        setStatus("Enter a valid email address.", "!text-coral");
        emailInput?.focus();
        return;
      }

      if (button) {
        button.disabled = true;
        button.classList.remove("btn-primary--success");
        button.textContent = "Submitting...";
      }
      setStatus("", "");

      try {
        const response = await fetch(`/api/events/${slug}/apply${querySuffix}`, {
          method: "POST",
          body: new FormData(form)
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || "Unable to submit application.");
        }

        const fullNameValue = String(fullNameInput?.value || "").trim();
        if (fullNameValue) window.localStorage.setItem("hatch.participant.name", fullNameValue);
        if (emailValue) window.localStorage.setItem("hatch.participant.email", emailValue);

        setStatus(uiCopy.participant.apply.success, "!text-lime");
        if (button) {
          button.textContent = "Submitted";
          button.classList.add("btn-primary--success");
        }
        window.setTimeout(() => {
          window.location.href = routeBase;
        }, 1100);
      } catch (error) {
        const message = error instanceof Error ? error.message : "Unable to submit application.";
        setStatus(message, "!text-coral");
        if (button) {
          button.disabled = false;
          button.classList.remove("btn-primary--success");
          button.textContent = defaultLabel;
        }
      }
    });

    loadEvent();
  </script>
</BaseLayout>
