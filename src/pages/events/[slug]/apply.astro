---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Apply to Compete | Hatch">
  <section class="mx-auto w-full max-w-4xl px-6 py-16">
    <div class="card !p-12 relative overflow-hidden group">
      <div class="absolute inset-0 bg-gradient-to-br from-lime/5 via-transparent to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
      
      <div class="relative z-10 space-y-12">
        <div class="space-y-4">
          <div class="flex items-center gap-3">
              <a href=".." class="w-8 h-8 rounded-lg bg-cream/5 flex items-center justify-center hover:bg-cream/10 transition-colors">
                  <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><line x1="19" y1="12" x2="5" y2="12"></line><polyline points="12 19 5 12 12 5"></polyline></svg>
              </a>
              <span class="eyebrow !text-lime !bg-lime/10 !border-lime/20">Mission Entry</span>
          </div>
          <h1 class="text-4xl md:text-5xl font-bold tracking-tighter" data-event-title>Apply to Compete</h1>
          <p class="text-lg text-cream/50 leading-relaxed font-medium" data-event-tagline>Initialize your participation protocol. We'll synchronize your status shortly.</p>
        </div>

        <form class="space-y-10" data-form>
          <div class="grid md:grid-cols-2 gap-8">
            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Personnel Identifier</label>
                    <input class="input-field" name="fullName" required placeholder="Jordan Lee" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Communication Endpoint</label>
                    <input class="input-field" type="email" name="email" required placeholder="you@stellar.io" />
                </div>
                <div class="space-y-2">
                    <label class="form-label">Affiliation / Colony</label>
                    <input class="input-field" name="organization" placeholder="School, Hub, or Collective" />
                </div>
            </div>

            <div class="space-y-6">
                <div class="space-y-2">
                    <label class="form-label">Primary Specialization</label>
                    <select class="input-field" name="role" required>
                        <option value="">Select Specialization</option>
                        <option>Architect (Developer)</option>
                        <option>Designer (UI/UX)</option>
                        <option>Strategist (Business)</option>
                        <option>Synthesizer (AI/Data)</option>
                        <option>Other</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="form-label">Target Track</label>
                    <select class="input-field" name="track" required data-track-select>
                        <option value="">Choose an objective...</option>
                    </select>
                </div>
                <div class="space-y-2">
                    <label class="form-label">Synchronization Mode</label>
                    <input class="input-field" name="location" placeholder="Chicago / UTC-6" />
                </div>
            </div>
          </div>

          <div class="space-y-6 pt-6 border-t border-cream/5">
            <div class="grid md:grid-cols-2 gap-8">
                <div class="space-y-2">
                    <label class="form-label">Squad Configuration</label>
                    <select class="input-field" name="teamStatus" required>
                        <option value="">Select configuration</option>
                        <option>Solo Operator (Looking for Squad)</option>
                        <option>Squad Leader (Have a Team)</option>
                        <option>Flexible (Open to Either)</option>
                    </select>
                </div>
                <div class="flex items-center h-full pt-8">
                    <label class="flex items-start gap-4 cursor-pointer group">
                        <input type="checkbox" name="consent" required class="w-6 h-6 rounded-lg bg-cream/5 border border-cream/10 accent-lime cursor-pointer mt-1" />
                        <span class="text-sm text-cream/40 group-hover:text-cream/60 transition-colors pt-1">
                            I verify compliance with the <a class="text-lime font-bold hover:underline" href="/code-of-conduct">Protocol of Conduct</a>.
                        </span>
                    </label>
                </div>
            </div>

            <div class="space-y-2">
                <label class="form-label">Mission Objectives (Optional)</label>
                <textarea class="input-field" name="idea" rows="4" placeholder="Briefly describe your proposed build or problem set."></textarea>
            </div>
          </div>

          <div class="pt-10 flex flex-col md:flex-row items-center justify-between gap-8">
              <div class="status-pill !bg-transparent !border-none hidden" data-status></div>
              <button class="btn-primary !px-16 !py-5 text-lg w-full md:w-auto" type="submit">Establish Participation</button>
          </div>
        </form>
      </div>
    </div>
  </section>

  <script>
    const pathParts = window.location.pathname.split("/").filter(Boolean);
    const slug = pathParts[pathParts.length - 2] || "";
    const organizerId = pathParts.length >= 4 ? pathParts[pathParts.length - 3] : "";
    const querySuffix = organizerId ? `?organizerId=${encodeURIComponent(organizerId)}` : "";
    const form = document.querySelector("[data-form]");
    const status = document.querySelector("[data-status]");
    const titleEl = document.querySelector("[data-event-title]");
    const taglineEl = document.querySelector("[data-event-tagline]");
    const trackSelect = document.querySelector("[data-track-select]");
    const button = form?.querySelector("button[type='submit']");
    const defaultLabel = button?.textContent;

    const loadEvent = async () => {
      try {
        const response = await fetch(`/api/events/${slug}${querySuffix}`);
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) throw new Error(payload.error || "Mission not found.");
        const { event, tracks } = payload;
        if (titleEl) titleEl.textContent = `Apply to ${event.title}`;
        if (taglineEl) taglineEl.textContent = event.tagline || "";
        if (trackSelect) {
          trackSelect.innerHTML = '<option value="">Choose an objective...</option>';
          tracks.forEach((track) => {
            const option = document.createElement("option");
            option.value = track.name;
            option.textContent = track.name;
            trackSelect.appendChild(option);
          });
        }
      } catch (error) {
        if (status) {
          status.textContent = "Signal failure: Event unavailable.";
          status.classList.remove("hidden");
          status.classList.add("!text-coral");
        }
        if (button) button.disabled = true;
      }
    };

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!status || !form) return;

      if (button) {
          button.disabled = true;
          button.classList.remove("btn-primary--success");
          button.textContent = "Synchronizing...";
      }
      status.textContent = "";
      status.classList.add("hidden");

      try {
        const response = await fetch(`/api/events/${slug}/apply${querySuffix}`, {
          method: "POST",
          body: new FormData(form)
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || "Uplink failure.");
        }
        status.textContent = "Entry established. Monitor your inbox for confirmation.";
        status.classList.remove("hidden");
        status.classList.add("!text-lime", "font-bold");
        form.reset();
        if (button) {
            button.textContent = "Success";
            button.classList.add("btn-primary--success");
        }
      } catch (error) {
        status.textContent = error.message;
        status.classList.remove("hidden");
        status.classList.add("!text-coral", "font-bold");
        if (button) {
            button.disabled = false;
            button.classList.remove("btn-primary--success");
            button.textContent = defaultLabel;
        }
      }
    });

    loadEvent();
  </script>
</BaseLayout>
