---
import BaseLayout from "../../../layouts/BaseLayout.astro";
---

<BaseLayout title="Apply | Hatch">
  <section class="mx-auto w-full max-w-4xl px-6 py-16">
    <div class="card space-y-6">
      <div>
        <span class="eyebrow">Registration</span>
        <h1 class="mt-4 text-3xl font-semibold md:text-4xl" data-event-title>
          Apply to compete
        </h1>
        <p class="mt-3 text-cream-70" data-event-tagline>
          Tell us about yourself and we’ll confirm your spot.
        </p>
      </div>

      <form class="grid gap-6" method="post" action="/api/events" data-form>
        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="form-label">Full name</span>
            <input class="input-field" name="fullName" required placeholder="Jordan Lee" />
          </label>
          <label class="grid gap-2">
            <span class="form-label">Email</span>
            <input class="input-field" type="email" name="email" required placeholder="you@email.com" />
          </label>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="form-label">Organization</span>
            <input class="input-field" name="organization" placeholder="School, company, or community" />
          </label>
          <label class="grid gap-2">
            <span class="form-label">Role</span>
            <select class="input-field" name="role" required>
              <option value="">Choose one</option>
              <option>Student</option>
              <option>Professional</option>
              <option>Designer</option>
              <option>Developer</option>
              <option>Other</option>
            </select>
          </label>
        </div>

        <div class="grid gap-4 md:grid-cols-2">
          <label class="grid gap-2">
            <span class="form-label">Location / timezone</span>
            <input class="input-field" name="location" placeholder="Chicago, CST" />
          </label>
          <label class="grid gap-2">
            <span class="form-label">Track interest</span>
            <select class="input-field" name="track" required data-track-select>
              <option value="">Choose a track</option>
            </select>
          </label>
        </div>

        <label class="grid gap-2">
          <span class="form-label">Team status</span>
          <select class="input-field" name="teamStatus" required>
            <option value="">Select one</option>
            <option>Looking for a team</option>
            <option>Have a team</option>
            <option>Open to either</option>
          </select>
        </label>

        <label class="grid gap-2">
          <span class="form-label">What do you want to build?</span>
          <textarea
            class="input-field"
            name="idea"
            rows="4"
            placeholder="Share a project idea or problem you want to solve."
          ></textarea>
        </label>

        <label class="flex items-start gap-3 text-sm text-cream-80">
          <input type="checkbox" name="consent" required class="mt-1" />
          I agree to the <a class="underline" href="/code-of-conduct">code of conduct</a>.
        </label>

        <div class="flex flex-wrap items-center gap-4">
          <button class="btn-primary" type="submit">Submit application</button>
          <span class="status-pill" data-status aria-live="polite"></span>
        </div>
      </form>
    </div>
  </section>

  <script>
    const slug = window.location.pathname.split("/").filter(Boolean).slice(-2)[0];
    const form = document.querySelector("[data-form]");
    const status = document.querySelector("[data-status]");
    const titleEl = document.querySelector("[data-event-title]");
    const taglineEl = document.querySelector("[data-event-tagline]");
    const trackSelect = document.querySelector("[data-track-select]");
    const button = form?.querySelector("button[type='submit']");
    const defaultLabel = button?.textContent;

    const loadEvent = async () => {
      try {
        const response = await fetch(`/api/events/${slug}`);
        if (!response.ok) throw new Error("Event not found.");
        const { event, tracks } = await response.json();
        if (titleEl) titleEl.textContent = `Apply to ${event.title}`;
        if (taglineEl) taglineEl.textContent = event.tagline || "";
        if (trackSelect) {
          trackSelect.innerHTML = '<option value="">Choose a track</option>';
          tracks.forEach((track) => {
            const option = document.createElement("option");
            option.value = track.name;
            option.textContent = track.name;
            trackSelect.appendChild(option);
          });
        }
      } catch (error) {
        if (status) {
          status.textContent = "This event is unavailable.";
          status.style.color = "#ff7a7a";
        }
        if (button) button.disabled = true;
      }
    };

    form?.addEventListener("submit", async (event) => {
      event.preventDefault();
      if (!status || !form) return;

      status.textContent = "Submitting...";
      status.style.color = "rgba(254, 245, 230, 0.9)";
      if (button) button.disabled = true;

      try {
        const response = await fetch(`/api/events/${slug}/apply`, {
          method: "POST",
          body: new FormData(form)
        });
        const payload = await response.json().catch(() => ({}));
        if (!response.ok) {
          throw new Error(payload.error || "Something went wrong.");
        }
        status.textContent = "Application received. Check your email soon.";
        form.reset();
      } catch (error) {
        status.textContent = error.message || "Unable to submit right now.";
        status.style.color = "#ff7a7a";
      } finally {
        if (button) button.disabled = false;
        if (button) button.textContent = defaultLabel || "Submit application";
      }
    });

    loadEvent();
  </script>
</BaseLayout>
